public void atan2(final double[] y, final int yOffset,
                  final double[] x, final int xOffset,
                  final double[] result, final int resultOffset) {

    // Handle the (0,0) case to avoid division by zero
    if (Double.doubleToRawLongBits(x[xOffset]) == 0L && Double.doubleToRawLongBits(y[yOffset]) == 0L) {
        // Both zero
        // Determine quadrant using the sign of the arguments
        // We need to compute the correct value and derivatives
        // For simplicity, use Math.atan2 on the primitives? But we need to fill derivatives.
        // We'll compute only the value and set derivatives to 0.
        double value = FastMath.atan2(y[yOffset], x[xOffset]); // This will return correct sign for (0,0) cases
        result[resultOffset] = value;
        for (int i = 1; i < getSize(); ++i) {
            result[resultOffset + i] = 0.0;
        }
        return;
    }

    // compute r = sqrt(x^2+y^2)
    double[] tmp1 = new double[getSize()];
    multiply(x, xOffset, x, xOffset, tmp1, 0);      // x^2
    double[] tmp2 = new double[getSize()];
    multiply(y, yOffset, y, yOffset, tmp2, 0);      // y^2
    add(tmp1, 0, tmp2, 0, tmp2, 0);                 // x^2 + y^2
    rootN(tmp2, 0, 2, tmp1, 0);                     // r = sqrt(x^2 + y^2)

    if (x[xOffset] >= 0) {

        // compute atan2(y, x) = 2 atan(y / (r + x))
        add(tmp1, 0, x, xOffset, tmp2, 0);          // r + x
        divide(y, yOffset, tmp2, 0, tmp1, 0);       // y /(r + x)
        atan(tmp1, 0, tmp2, 0);                     // atan(y / (r + x))
        for (int i = 0; i < tmp2.length; ++i) {
            result[resultOffset + i] = 2 * tmp2[i]; // 2 * atan(y / (r + x))
        }

    } else {

        // compute atan2(y, x) = +/- pi - 2 atan(y / (r - x))
        subtract(tmp1, 0, x, xOffset, tmp2, 0);     // r - x
        divide(y, yOffset, tmp2, 0, tmp1, 0);       // y /(r - x)
        atan(tmp1, 0, tmp2, 0);                     // atan(y / (r - x))
        // Determine the sign based on y, respecting signed zero
        if (Double.compare(y[yOffset], 0.0) < 0) {
            result[resultOffset] = -FastMath.PI - 2 * tmp2[0]; // -pi - 2 * atan(y / (r - x))
        } else {
            result[resultOffset] = FastMath.PI - 2 * tmp2[0]; // pi - 2 * atan(y / (r - x))
        }
        for (int i = 1; i < tmp2.length; ++i) {
            result[resultOffset + i] = -2 * tmp2[i]; // derivatives: no pi term
        }
    }
}
```

