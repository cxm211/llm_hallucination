public static Vector3D crossProduct(final Vector3D v1, final Vector3D v2) {
    // preconditioning to reduce cancellation errors
    // compute rho as an 8-bit approximation of v1.v2 / v2.v2
    double dot12 = v1.x * v2.x + v1.y * v2.y + v1.z * v2.z;
    double dot22 = v2.x * v2.x + v2.y * v2.y + v2.z * v2.z;
    // If v2 is zero, cross product is zero
    if (dot22 == 0) {
        return new Vector3D(0, 0, 0);
    }
    double rho = Math.floor(dot12 / dot22 * 256.0 + 0.5) / 256.0; // round to nearest 1/256
    double v3x = v1.x - rho * v2.x;
    double v3y = v1.y - rho * v2.y;
    double v3z = v1.z - rho * v2.z;
    // compute cross product of v3 and v2
    return new Vector3D(v3y * v2.z - v3z * v2.y,
                        v3z * v2.x - v3x * v2.z,
                        v3x * v2.y - v3y * v2.x);
}

