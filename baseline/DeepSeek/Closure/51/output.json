void addNumber(double x) {
    char prev = getLastChar();
    if (x < 0 && prev == '-') {
      add(" ");
    }

    if ((long) x == x) {
      long value = (long) x;
      if (Math.abs(x) >= 100) {
        long mantissa = value;
        int exp = 0;
        while (mantissa % 10 == 0 && mantissa != 0) {
          mantissa /= 10;
          exp++;
        }
        if (exp > 2) {
          add(Long.toString(mantissa) + "E" + Integer.toString(exp));
        } else {
          add(Long.toString(value));
        }
      } else {
        add(Long.toString(value));
      }
    } else {
      add(String.valueOf(x));
    }
  }

