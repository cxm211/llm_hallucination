            result.append('J');
        } else {
            result.append('J', 'K');
        }
        index += 2;
    } else if (charAt(value, index + 1) == 'G') {
        index += 2;
        result.append('K');
    } else {
        index++;
        result.append('K');
    }
    return index;
}
