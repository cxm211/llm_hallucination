public long adjustOffset(long instant, boolean earlierOrLater) {
    long instantBefore = convertUTCToLocal(instant - 3 * DateTimeConstants.MILLIS_PER_HOUR);
    long instantAfter = convertUTCToLocal(instant + 3 * DateTimeConstants.MILLIS_PER_HOUR);
    if (instantBefore == instantAfter) {
        return instant;
    }
    long local = convertUTCToLocal(instant);
    // Compute the two possible UTC instants for the same local time.
    long utc1 = convertLocalToUTC(local, false, instant);
    // To get the second, use a reference far from the first.
    long utc2;
    if (earlierOrLater) {
        utc2 = convertLocalToUTC(local, false, utc1 - 24 * DateTimeConstants.MILLIS_PER_HOUR);
    } else {
        utc2 = convertLocalToUTC(local, false, utc1 + 24 * DateTimeConstants.MILLIS_PER_HOUR);
    }
    // The two are different. Choose the one that matches the flag.
    if (earlierOrLater) {
        // We want the later offset, which corresponds to the earlier UTC instant.
        return Math.min(utc1, utc2);
    } else {
        return Math.max(utc1, utc2);
    }
}
```

