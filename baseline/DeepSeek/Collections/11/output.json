private void calculateHashCode(Object[] keys) {
    int total = 0;
    if (keys != null) {
        for (int i = 0; i < keys.length; i++) {
            if (keys[i] != null) {
                total = 31 * total + keys[i].hashCode();
            } else {
                total = 31 * total + 0;
            }
        }
    }
    hashCode = total;
}
```

