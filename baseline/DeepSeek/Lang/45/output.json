```
public static String abbreviate(String str, int lower, int upper, String appendToEnd) {
    if (str == null) {
        return null;
    }
    if (str.length() == 0) {
        return StringUtils.EMPTY;
    }
    if (upper == -1 || upper > str.length()) {
        upper = str.length();
    }
    if (upper < lower) {
        upper = lower;
    }
    // If the string fits within upper, return it as is
    if (str.length() <= upper) {
        return str;
    }
    // Minimum length of the text part considering appendToEnd
    int appendLen = StringUtils.defaultString(appendToEnd).length();
    // Maximum length of the text part without exceeding upper
    int maxTextLen = upper - appendLen;
    // Ensure maxTextLen is at least lower
    if (maxTextLen < lower) {
        // If even the lower number of characters cannot be accommodated with the append string,
        // we have to make the text part at least lower, which may exceed upper.
        maxTextLen = lower;
    }
    StringBuffer result = new StringBuffer();
    int index = StringUtils.indexOf(str, " ", lower);
    if (index == -1) {
        // No space found, truncate at maxTextLen
        int end = Math.min(str.length(), maxTextLen);
        result.append(str.substring(0, end));
        if (end < str.length()) {
            result.append(StringUtils.defaultString(appendToEnd));
        }
    } else if (index > maxTextLen) {
        // Space found but too far, truncate at maxTextLen
        int end = Math.min(str.length(), maxTextLen);
        result.append(str.substring(0, end));
        result.append(StringUtils.defaultString(appendToEnd));
    } else {
        // Space found within maxTextLen, use it
        result.append(str.substring(0, index));
        result.append(StringUtils.defaultString(appendToEnd));
    }
    return result.toString();
}
```

