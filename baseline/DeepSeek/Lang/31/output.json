public static boolean containsAny(CharSequence cs, char[] searchChars) {
    if (isEmpty(cs) || ArrayUtils.isEmpty(searchChars)) {
        return false;
    }
    int csLength = cs.length();
    int searchLength = searchChars.length;
    // Build a set of BMP characters from searchChars
    Set<Character> bmpSet = new HashSet<Character>();
    // For supplementary characters in searchChars, we need to handle pairs
    Set<Integer> suppSet = new HashSet<Integer>();
    for (int i = 0; i < searchLength; i++) {
        char c = searchChars[i];
        if (Character.isHighSurrogate(c) && i + 1 < searchLength && Character.isLowSurrogate(searchChars[i+1])) {
            int codePoint = Character.toCodePoint(c, searchChars[i+1]);
            suppSet.add(codePoint);
            i++; // skip low surrogate
        } else {
            bmpSet.add(c);
        }
    }
    // Iterate over code points of cs
    for (int i = 0; i < csLength; ) {
        int cp = Character.codePointAt(cs, i);
        if (cp < Character.MIN_SUPPLEMENTARY_CODE_POINT) {
            if (bmpSet.contains((char) cp)) {
                return true;
            }
        } else {
            if (suppSet.contains(cp)) {
                return true;
            }
        }
        i += Character.charCount(cp);
    }
    return false;
}
```

