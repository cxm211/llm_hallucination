        for (int i = 0; i < typeVars.length; i++) {
            result.put(typeVars[i], actualTypeArgs[i]);
        }
        // now recurse on raw class
        return getTypeArguments(rawCls, toClass, result);
    }

    // handle TypeVariable
    if (type instanceof TypeVariable<?>) {
        TypeVariable<?> typeVar = (TypeVariable<?>) type;
