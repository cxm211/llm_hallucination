    "public JsonWriter nullValue() throws IOException {\n    if (deferredName != null) {\n      if (serializeNulls) {\n        writeDeferredName();\n      } else {\n        deferredName = null;\n        return this;\n      }\n    }\n    beforeValue(false);\n    out.write(\"null\");\n    return this;\n  }",
