private String getNamespace(org.jsoup.nodes.Element el, String prefix) {
    // search for xmlns:prefix or xmlns if prefix empty
    String attrKey = prefix.isEmpty() ? "xmlns" : "xmlns:" + prefix;
    // search on element and its ancestors
    org.jsoup.nodes.Element current = el;
    while (current != null) {
        if (current.hasAttr(attrKey)) {
            return current.attr(attrKey);
        }
        current = current.parent();
    }
    return null;
}
```

