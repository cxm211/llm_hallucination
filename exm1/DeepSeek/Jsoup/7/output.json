        TextNode node = toMove.get(i);
        body().prependChild(new TextNode(" ", ""));
        body().prependChild(node);
    }
    return this;
}

private void collectTextNodesToMove(Element start, List<TextNode> out) {
    // Traverse immediate children of start, but if we encounter a body element, skip it.
    for (Node child : start.childNodes) {
        if (child instanceof TextNode) {
            TextNode tn = (TextNode) child;
            if (!tn.isBlank()) {
