static Document parseByteData(ByteBuffer byteData, String charsetName, String baseUri, Parser parser) {
    String docData;
    Document doc = null;
    if (charsetName == null) {
        docData = Charset.forName(defaultCharset).decode(byteData).toString();
        doc = parser.parseInput(docData, baseUri);
        Element meta = doc.select("meta[http-equiv=content-type], meta[charset]").first();
        if (meta != null) {
            String foundCharset;
            if (meta.hasAttr("http-equiv")) {
                foundCharset = getCharsetFromContentType(meta.attr("content"));
            } else {
                foundCharset = meta.attr("charset");
                // Clean charset: remove quotes and trim
                foundCharset = cleanCharset(foundCharset);
            }
            if (foundCharset != null && !foundCharset.isEmpty() && !foundCharset.equals(defaultCharset)) {
                charsetName = foundCharset;
                byteData.rewind();
                try {
                    docData = Charset.forName(foundCharset).decode(byteData).toString();
                } catch (Exception e) {
                    // if charset is invalid, continue with original
                    charsetName = defaultCharset;
                    docData = null; // force reparse with original?
                }
                doc = null;
            }
        }
    } else {
        Validate.notEmpty(charsetName, "Must set charset arg...");
        docData = Charset.forName(charsetName).decode(byteData).toString();
    }
    if (doc == null) {
        if (docData != null && docData.length() > 0 && docData.charAt(0) == 65279)
            docData = docData.substring(1);
        doc = parser.parseInput(docData, baseUri);
        doc.outputSettings().charset(charsetName);
    }
    return doc;
}

static String getCharsetFromContentType(String contentType) {
    if (contentType == null) return null;
    Pattern charsetPattern = Pattern.compile("charset\\s*=\\s*[\"']?([^\"';\",\\s]+)", Pattern.CASE_INSENSITIVE);
    Matcher m = charsetPattern.matcher(contentType);
    if (m.find()) {
        String charset = m.group(1).trim();
        // Handle duplicate "charset=" prefix
        while (charset.startsWith("charset=")) {
            charset = charset.substring("charset=".length()).trim();
        }
        // Remove surrounding quotes if any
        if (charset.startsWith("\"") || charset.startsWith("'")) {
            charset = charset.substring(1);
        }
        if (charset.endsWith("\"") || charset.endsWith("'")) {
            charset = charset.substring(0, charset.length()-1);
        }
        charset = charset.trim();
        if (charset.isEmpty()) return null;
        try {
            if (Charset.isSupported(charset)) return charset;
            charset = charset.toUpperCase(Locale.ENGLISH);
            if (Charset.isSupported(charset)) return charset;
        } catch (IllegalArgumentException e) {
            return null;
        }
    }
    return null;
}

// helper method
private static String cleanCharset(String charset) {
    if (charset == null || charset.isEmpty()) return charset;
    charset = charset.trim();
    if (charset.startsWith("\"") || charset.startsWith("'")) charset = charset.substring(1);
    if (charset.endsWith("\"") || charset.endsWith("'")) charset = charset.substring(0, charset.length()-1);
    return charset.trim();
}
