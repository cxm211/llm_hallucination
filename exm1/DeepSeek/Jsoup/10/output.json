    assertEquals("http://bar/qux", noBase.absUrl("absHref")); // absolute -> returns itself

    Element withBase = new Element(tag, "http://foo/", attribs);
    assertEquals("http://foo/foo", withBase.absUrl("relHref")); // resolved
    assertEquals("http://bar/qux", withBase.absUrl("absHref")); // absolute -> still returns itself
    assertEquals("", withBase.absUrl("noval")); // not present -> empty

    Element dodgyBase = new Element(tag, "wtf://no-such-protocol/", attribs);
    assertEquals("http://bar/qux", dodgyBase.absUrl("absHref")); // absolute attribute works
    assertEquals("", dodgyBase.absUrl("relHref")); // relative attribute -> empty because base is invalid
}
```

