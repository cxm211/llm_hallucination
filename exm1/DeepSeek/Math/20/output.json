public double[] repairAndDecode(final double[] x) {
    // repair: clamp to bounds
    for (int i = 0; i < x.length; i++) {
        if (x[i] < 0) x[i] = 0;
        else if (x[i] > 1.0) x[i] = 1.0;
    }
    return decode(x);
}
