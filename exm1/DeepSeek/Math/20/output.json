public double[] repairAndDecode(final double[] x) {
    // clamp to [0,1] which is the normalized range
    double[] repaired = new double[x.length];
    for (int i = 0; i < x.length; i++) {
        if (x[i] < 0.0) {
            repaired[i] = 0.0;
        } else if (x[i] > 1.0) {
            repaired[i] = 1.0;
        } else {
            repaired[i] = x[i];
        }
    }
    return decode(repaired);
}
Or more concisely:
public double[] repairAndDecode(final double[] x) {
    double[] repaired = x.clone();
    for (int i = 0; i < repaired.length; i++) {
        if (repaired[i] < 0) repaired[i] = 0;
        if (repaired[i] > 1) repaired[i] = 1;
    }
    return decode(repaired);
}
