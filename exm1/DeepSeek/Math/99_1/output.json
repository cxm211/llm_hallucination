public static int gcd(final int p, final int q) {
    int u = p;
    int v = q;
    if ((u == 0) || (v == 0)) {
        int absU = Math.abs(u);
        int absV = Math.abs(v);
        // If either absolute value is Integer.MIN_VALUE, overflow occurs
        if (absU == Integer.MIN_VALUE || absV == Integer.MIN_VALUE) {
            throw MathRuntimeException.createArithmeticException(
                "overflow: gcd({0}, {1}) is 2^31",
                new Object[] { p, q });
        }
        return absU + absV;
    }
    // rest unchanged
}

