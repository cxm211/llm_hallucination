public void atan2(final double[] y, final int yOffset,
                  final double[] x, final int xOffset,
                  final double[] result, final int resultOffset) {

    // handle special cases
    if (x[xOffset] == 0 && y[yOffset] == 0) {
        result[resultOffset] = 0.0;
        for (int i = 1; i < result.length - resultOffset; ++i) {
            result[resultOffset + i] = 0.0; // derivatives might be undefined, set to 0
        }
        return;
    }
    if (Double.isInfinite(x[xOffset]) || Double.isInfinite(y[yOffset])) {
        // compute atan2 for infinite values
        if (y[yOffset] == 0) {
            if (x[xOffset] > 0) {
                result[resultOffset] = 0.0;
            } else {
                result[resultOffset] = FastMath.PI;
            }
        } else if (x[xOffset] == 0) {
            if (y[yOffset] > 0) {
                result[resultOffset] = FastMath.PI / 2;
            } else {
                result[resultOffset] = -FastMath.PI / 2;
            }
        } else {
            // both finite? actually infinite
            // Use standard atan2 logic for infinities
            if (Double.isInfinite(y[yOffset]) && Double.isInfinite(x[xOffset])) {
                if (y[yOffset] > 0 && x[xOffset] > 0) {
                    result[resultOffset] = FastMath.PI / 4;
                } else if (y[yOffset] > 0 && x[xOffset] < 0) {
                    result[resultOffset] = 3 * FastMath.PI / 4;
                } else if (y[yOffset] < 0 && x[xOffset] > 0) {
                    result[resultOffset] = -FastMath.PI / 4;
                } else if (y[yOffset] < 0 && x[xOffset] < 0) {
                    result[resultOffset] = -3 * FastMath.PI / 4;
                } else if (y[yOffset] > 0) {
                    result[resultOffset] = FastMath.PI / 2;
                } else if (y[yOffset] < 0) {
                    result[resultOffset] = -FastMath.PI / 2;
                }
            } else if (Double.isInfinite(y[yOffset])) {
                if (y[yOffset] > 0) {
                    result[resultOffset] = FastMath.PI / 2;
                } else {
                    result[resultOffset] = -FastMath.PI / 2;
                }
            } else { // x infinite, y finite
                if (x[xOffset] > 0) {
                    result[resultOffset] = 0.0;
                } else {
                    if (y[yOffset] >= 0) {
                        result[resultOffset] = FastMath.PI;
                    } else {
                        result[resultOffset] = -FastMath.PI;
                    }
                }
            }
        }
        // for higher-order derivatives, set to 0 (since constant or sign changes)
        for (int i = 1; i < result.length - resultOffset; ++i) {
            result[resultOffset + i] = 0.0;
        }
        return;
    }

    // original algorithm
    double[] tmp1 = new double[getSize()];
    multiply(x, xOffset, x, xOffset, tmp1, 0);      // x^2
    double[] tmp2 = new double[getSize()];
    multiply(y, yOffset, y, yOffset, tmp2, 0);      // y^2
    add(tmp1, 0, tmp2, 0, tmp2, 0);                 // x^2 + y^2
    rootN(tmp2, 0, 2, tmp1, 0);                     // r = sqrt(x^2 + y^2)

    if (x[xOffset] >= 0) {
        add(tmp1, 0, x, xOffset, tmp2, 0);          // r + x
        divide(y, yOffset, tmp2, 0, tmp1, 0);       // y /(r + x)
        atan(tmp1, 0, tmp2, 0);                     // atan(y / (r + x))
