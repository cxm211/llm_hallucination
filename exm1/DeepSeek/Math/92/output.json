    public static long binomialCoefficient(final int n, final int k) {
        if (n < k) {
            throw new IllegalArgumentException(
                "must have n >= k for binomial coefficient (n,k)");
        }
        if (n < 0) {
            throw new IllegalArgumentException(
                "must have n >= 0 for binomial coefficient (n,k)");
        }
        if ((n == k) || (k == 0)) {
            return 1;
        }
        if ((k == 1) || (k == n - 1)) {
            return n;
        }
        if (k > n - k) {
            return binomialCoefficient(n, n - k);
        }
        // Use integer arithmetic
        long result = 1;
        for (int i = 1; i <= k; i++) {
            long term = n - k + i;
            long gcd = gcd(result, i);
            result = (result / gcd) * (term / (i / gcd));
            // Check for overflow: if multiplication overflowed, result will be negative or something? Not reliable.
            // We can check if result could have overflowed by comparing with previous value.
            // Simpler: if result > Long.MAX_VALUE / termAfterDivision, then overflow.
            // But we do division before multiplication, so the multiplication is result * (term / (i/gcd)).
            // Let's compute after multiplication and throw if overflow.
        }
        if (result < 0) {
            // This is not a perfect check; but best we can do.
            throw new ArithmeticException(
                "result too large to represent in a long integer");
        }
        return result;
    }

    private static long gcd(long a, long b) {
        while (b != 0) {
            long temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }
