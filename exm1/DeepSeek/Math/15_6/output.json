            if (y == yi && (yi & 1) == 1) {
                return -0.0;
            }

            return 0.0;
        }

        if (y > 0)  {
            long yi = (long) y;
            if (y == yi && (yi & 1) == 1) {
                return Double.NEGATIVE_INFINITY;
            }

            return Double.POSITIVE_INFINITY;
        }
    }

    if (y == Double.NEGATIVE_INFINITY) {

        if (x * x == 1.0) {
            return Double.NaN;
        }

        if (x * x < 1.0) {
            return Double.POSITIVE_INFINITY;
        } else {
