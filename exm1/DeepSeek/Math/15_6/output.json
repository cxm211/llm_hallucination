        if (y >= TWO_POWER_52 || y <= -TWO_POWER_52) {
            return (y % 2.0 == 0.0) ? pow(-x, y) : -pow(-x, y);
        }

        if (y == (long) y) {
            // If y is an integer
            return ((long)y & 1) == 0 ? pow(-x, y) : -pow(-x, y);
        } else {
            return Double.NaN;
        }
    }

    /* Split y into ya and yb such that y = ya+yb */
    double ya;
