```java
public ChangeSetResults perform(ArchiveInputStream in, ArchiveOutputStream out)
        throws IOException {
    ChangeSetResults results = new ChangeSetResults();
    
    // Build set of deleted names (exact files and directory prefixes)
    Set<String> deletedNames = new HashSet<String>();
    for (Iterator it = changes.iterator(); it.hasNext();) {
        Change change = (Change) it.next();
        if (change.type() == Change.TYPE_DELETE) {
            deletedNames.add(change.targetFile());
        } else if (change.type() == Change.TYPE_DELETE_DIR) {
            // Add directory prefix with trailing slash for later checks
            deletedNames.add(change.targetFile() + "/");
        }
    }
    
    // Map from entry name to replaceMode add if present
    Map<String, Change> replaceAdds = new HashMap<String, Change>();
    for (Iterator it = changes.iterator(); it.hasNext();) {
        Change change = (Change) it.next();
        if (change.type() == Change.TYPE_ADD && change.isReplaceMode()) {
            replaceAdds.put(change.getEntry().getName(), change);
        }
    }
    
    // Process archive entries
    ArchiveEntry entry = null;
    while ((entry = in.getNextEntry()) != null) {
        String name = entry.getName();
        if (name == null) continue;
        
        // Check if entry should be deleted
        boolean isDeleted = false;
        for (String d : deletedNames) {
            if (d.endsWith("/")) {
                // directory prefix
                if (name.startsWith(d)) {
                    isDeleted = true;
                    break;
                }
            } else {
                if (name.equals(d)) {
                    isDeleted = true;
                    break;
                }
            }
        }
        
        if (isDeleted) {
            results.deleted(name);
            // Still need to consume the entry data
            IOUtils.copy(in, new ByteArrayOutputStream());
            continue;
        }
        
        // Check if there is a replaceMode add for this entry
        Change replaceChange = replaceAdds.get(name);
        if (replaceChange != null) {
            // Write the new content and record it
            copyStream(replaceChange.getInput(), out, replaceChange.getEntry());
            results.addedFromChangeSet(name);
            // Mark this add as used by removing from map
            replaceAdds.remove(name);
            // Consume the original entry data (skip)
            IOUtils.copy(in, new ByteArrayOutputStream());
        } else if (!results.hasBeenAdded(name)) {
            // Copy original entry
            copyStream(in, out, entry);
            results.addedFromStream(name);
        } else {
            // Entry already added (should not happen)
            IOUtils.copy(in, new ByteArrayOutputStream());
        }
    }
    
    // Process remaining adds that are not replacements and not deleted
    for (Iterator it = changes.iterator(); it.hasNext();) {
        Change change = (Change) it.next();
        if (change.type() == Change.TYPE_ADD) {
            String name = change.getEntry().getName();
            if (name == null) continue;
            
            // Skip if already added from stream (replaceMod adds already processed)
            if (results.hasBeenAdded(name)) continue;
            
            // Check if this add would be deleted
            boolean isDeleted = false;
            for (String d : deletedNames) {
                if (d.endsWith("/")) {
                    if (name.startsWith(d)) {
                        isDeleted = true;
                        break;
                    }
                } else {
                    if (name.equals(d)) {
                        isDeleted = true;
                        break;
                    }
                }
            }
            if (isDeleted) continue;
            
            // Copy the new content
            copyStream(change.getInput(), out, change.getEntry());
            results.addedFromChangeSet(name);
        }
    }
    
    return results;
}
```

