    if (currEntry == null) {
        throw new IllegalStateException("No current tar entry");
    }

    // numToRead = Math.min(numToRead, available());  // removed
    
    totalRead = is.read(buf, offset, numToRead);
    count(totalRead);
    
    if (totalRead == -1) {
        hasHitEOF = true;
    } else {
        entryOffset += totalRead;
    }

    return totalRead;
}
```

