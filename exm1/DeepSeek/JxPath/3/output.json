        pointer.setValue(value);
        return pointer;
    } else {
        if (newParent instanceof PropertyOwnerPointer) {
            return ((PropertyOwnerPointer) newParent).createChild(context, getName(), index, value);
        }
        return newParent.createChild(context, getName(), index, value);
    }
}

