protected String[] flatten(Options options, String[] arguments, boolean stopAtNonOption)
{
    init();
    this.options = options;

    Iterator iter = Arrays.asList(arguments).iterator();

    while (iter.hasNext())
    {
        String token = (String) iter.next();

        if (token.startsWith("--"))
        {
            // handle long option with '='
            if (token.indexOf('=') != -1)
            {
                tokens.add(token.substring(0, token.indexOf('=')));
                tokens.add(token.substring(token.indexOf('=') + 1, token.length()));
            }
            else
            {
                tokens.add(token);
            }
        }
        else if ("-".equals(token))
        {
            processSingleHyphen(token);
        }
        else if (token.startsWith("-"))
        {
            // For tokens starting with a single dash, first check if it could be a long option (single-dash long option)
            String withoutDash = token.substring(1);
            int eqIndex = withoutDash.indexOf('=');
            String optKey = (eqIndex != -1) ? withoutDash.substring(0, eqIndex) : withoutDash;
            if (options.hasOption(optKey))
            {
                // This token is recognized as an option; treat it as such.
                // For consistency with double-dash handling, we split on '=' if present.
                if (eqIndex != -1)
                {
                    tokens.add("-" + optKey); // e.g., "-age"
                    tokens.add(withoutDash.substring(eqIndex + 1));
                }
                else
                {
                    tokens.add(token);
                }
            }
            else if (token.length() == 2)
            {
                processOptionToken(token, stopAtNonOption);
            }
            else if (options.hasOption(token))
            {
                tokens.add(token);
            }
            else
            {
                burstToken(token, stopAtNonOption);
            }
        }
        else if (stopAtNonOption)
        {
            process(token);
        }
        else
        {
            tokens.add(token);
        }

        gobble(iter);
    }

    return (String[]) tokens.toArray(new String[tokens.size()]);
}
```

