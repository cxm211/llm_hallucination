public int getOffsetFromLocal(long instantLocal) {
    final int offsetLocal = getOffset(instantLocal);
    final long instantAdjusted = instantLocal - offsetLocal;
    final int offsetAdjusted = getOffset(instantAdjusted);
    if (offsetLocal != offsetAdjusted) {
        if ((offsetLocal - offsetAdjusted) < 0) {
            // Spring forward gap
            long nextLocal = nextTransition(instantAdjusted);
            if (nextLocal != Long.MIN_VALUE) {
                if (instantLocal - offsetLocal < nextLocal) {
                    // Not in gap, use original offset
                    return offsetLocal;
                }
                // In gap, use adjusted offset (larger)
                return offsetAdjusted;
            }
        } else {
            // Fall back overlap
            long prevLocal = previousTransition(instantAdjusted);
            if (prevLocal != Long.MIN_VALUE) {
                if (instantLocal - offsetLocal > prevLocal) {
                    // In overlap, use original offset (smaller)
                    return offsetLocal;
                }
                // Not in overlap, use adjusted offset
                return offsetAdjusted;
            }
        }
    }
    return offsetAdjusted;
}
```

