public int calculatePrintedLength(ReadablePeriod period, Locale locale) {
    long valueLong = getFieldValue(period);
    if (valueLong == Long.MAX_VALUE) {
        return 0;
    }

    int sum;
    if (iFieldType >= SECONDS_MILLIS) {
        // Extract seconds and millis
        long seconds = valueLong / DateTimeConstants.MILLIS_PER_SECOND;
        // For negative values, we need to handle correctly: seconds = floor division
        // Use: if (valueLong < 0 && valueLong % MILLIS_PER_SECOND != 0) seconds--;
        // But simpler: compute millis as remainder, then adjust
        int millis;
        if (valueLong < 0) {
            seconds = (valueLong - (DateTimeConstants.MILLIS_PER_SECOND - 1)) / DateTimeConstants.MILLIS_PER_SECOND;
            millis = (int)(valueLong - (seconds * DateTimeConstants.MILLIS_PER_SECOND));
        } else {
            seconds = valueLong / DateTimeConstants.MILLIS_PER_SECOND;
            millis = (int)(valueLong % DateTimeConstants.MILLIS_PER_SECOND);
        }
        // Now compute sum based on seconds part
        sum = Math.max(FormatUtils.calculateDigitCount(seconds), iMinPrintedDigits);
        // For the decimal part:
        if (iFieldType == SECONDS_MILLIS || (iFieldType == SECONDS_OPTIONAL_MILLIS && millis != 0)) {
            // We need at least 4 digits for millis? Actually the decimal part consists of '.' and 3 digits.
            // But the sum currently includes only seconds digits. We need to add 4 for the decimal part.
            sum += 4; // '.' plus 3 digits
        }
        // If iFieldType == SECONDS_OPTIONAL_MILLIS and millis == 0, no decimal part, sum stays as above.
        // Also ensure sum is at least 4? Not needed because seconds part alone might be 0, but then we need at least 1 digit? Actually if seconds is 0, digit count is 1. So fine.
        // Reset valueLong to seconds for prefix/suffix
        valueLong = seconds;
    } else {
        sum = Math.max(FormatUtils.calculateDigitCount(valueLong), iMinPrintedDigits);
    }

    int value = (int) valueLong;

    if (iPrefix != null) {
        sum += iPrefix.calculatePrintedLength(value);
    }
    if (iSuffix != null) {
        sum += iSuffix.calculatePrintedLength(value);
    }

    return sum;
}
```

