public int compareTo(DurationField other) {
    long thisMillis = getMillis();
    long otherMillis = other.getMillis();
    // cannot do (thisMillis - otherMillis) as can overflow
    if (thisMillis < otherMillis) {
        return -1;
    }
    if (thisMillis > otherMillis) {
        return 1;
    }
    return 0;
}
```
