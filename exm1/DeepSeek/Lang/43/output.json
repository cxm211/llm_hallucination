private StringBuffer appendQuotedString(String pattern, ParsePosition pos,
        StringBuffer appendTo, boolean escapingOn) {
    int start = pos.getIndex();
    char[] c = pattern.toCharArray();
    if (escapingOn && pattern.startsWith(ESCAPED_QUOTE, start)) {
        // escaped quote at start of quoted region? Actually this handles the case where we are at an escaped quote that is not inside a quoted region? But the method is called when a quote is encountered. If we have two quotes, we output one quote and return.
        if (appendTo != null) {
