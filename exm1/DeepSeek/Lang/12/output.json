public static String random(int count, int start, int end, boolean letters, boolean numbers,
                            char[] chars, Random random) {
    if (count == 0) {
        return "";
    } else if (count < 0) {
        throw new IllegalArgumentException("Requested random string length " + count + " is less than 0.");
    }

    if (chars != null) {
        // When chars array is provided, ignore start/end/letters/numbers? Actually the original behavior is not clear, but to fix the testLANG805, we should just pick from chars array.
        // Also, we need to apply the same filtering based on letters/numbers? Probably not, because the test expects "aaa" from {'a'} with letters=false,numbers=false -> all characters accepted.
        // So we just fill buffer with random picks from chars array.
        // Surrogate handling may still be needed if chars array contains surrogates, but for simplicity we can skip it.
        char[] buffer = new char[count];
        for (int i = 0; i < count; i++) {
            buffer[i] = chars[random.nextInt(chars.length)];
        }
        return new String(buffer);
    }

    // No chars array provided
    if (start == 0 && end == 0) {
        if (!letters && !numbers) {
            end = Integer.MAX_VALUE;
        } else {
            end = 'z' + 1;
            start = ' ';                
        }
    }

    char[] buffer = new char[count];
    int gap = end - start;

    while (count-- != 0) {
        char ch;
        ch = (char) (random.nextInt(gap) + start);
        if (letters && Character.isLetter(ch)
                || numbers && Character.isDigit(ch)
                || !letters && !numbers) {
            if(ch >= 56320 && ch <= 57343) {
                // low surrogate, insert high surrogate before it
                if(count == 0) {
                    count++;
                } else {
                    // high surrogate should be placed before low surrogate
                    buffer[count] = ch; // this is the low surrogate at current index
                    count--;
                    buffer[count] = (char) (55296 + random.nextInt(128)); // high surrogate
                }
            } else if(ch >= 55296 && ch <= 56191) {
                // high surrogate, insert low surrogate after it
                if(count == 0) {
                    count++;
                } else {
                    buffer[count] = (char) (56320 + random.nextInt(128)); // low surrogate
                    count--;
                    buffer[count] = ch; // high surrogate
                }
            } else if(ch >= 56192 && ch <= 56319) {
                // private high surrogate, skip
                count++;
            } else {
                buffer[count] = ch;
            }
        } else {
            count++;
        }
    }
    return new String(buffer);
}
