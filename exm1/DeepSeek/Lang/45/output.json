public static String abbreviate(String str, int lower, int upper, String appendToEnd) {
    if (str == null) return null;
    if (str.length() == 0) return "";
    // adjust lower
    if (lower < 0) lower = 0;
    if (lower > str.length()) lower = str.length();
    // adjust upper
    if (upper == -1 || upper > str.length()) upper = str.length();
    if (upper < lower) upper = lower;
    // find the last space <= upper
    int index = StringUtils.lastIndexOf(str, " ", upper);
    // but lastIndexOf might be lower than lower? Actually we want the last space before or at upper, but also >= lower? The standard behavior is to try to break at a space after lower but before upper. If no space in that range, then break at upper. So we should find the last space index between lower and upper inclusive.
    // We can do: int index = str.lastIndexOf(' ', upper);
    // but that may give a space before lower. So after getting index, we should check if index >= lower.
    if (index == -1 || index < lower) {
        // no space in range, just truncate at upper
        result.append(str.substring(0, upper));
        if (upper != str.length()) {
            result.append(StringUtils.defaultString(appendToEnd));
        }
    } else {
        // space found at index, truncate at that space
        result.append(str.substring(0, index));
        result.append(StringUtils.defaultString(appendToEnd));
    }
    // Note: need to handle the case where the truncation at upper would cut a word? Actually if index < lower, we truncate at upper. That might cut a word, but that's the intended behavior when no space in range.
}

