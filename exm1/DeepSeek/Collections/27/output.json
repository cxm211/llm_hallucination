    try {
        return clazz.newInstance();
    } catch (final InstantiationException ex) {
        throw new FunctorException("Cannot instantiate class: " + clazz, ex);
    } catch (final IllegalAccessException ex) {
        throw new FunctorException("Cannot instantiate class: " + clazz, ex);
    }
}
```

