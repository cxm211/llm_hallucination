public boolean addAll(int index, Collection coll) {
    int sizeBefore = size();
    for (Iterator it = coll.iterator(); it.hasNext();) {
        Object obj = it.next();
        if (!set.contains(obj)) {
            list.add(index, obj);
            set.add(obj);
            index++;
        }
    }
    return sizeBefore != size();
}
```

