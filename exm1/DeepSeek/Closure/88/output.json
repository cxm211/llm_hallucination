private VariableLiveness isVariableReadBeforeKill(
    Node n, String variable) {
  if (NodeUtil.isName(n) && variable.equals(n.getString())) {
    if (NodeUtil.isLhs(n, n.getParent())) {
      // This is handled at the assignment level.
      // Do nothing here; the kill is processed after the RHS.
    } else {
      return VariableLiveness.READ;
    }
  }

  // Special handling for assignments: process RHS before LHS.
  boolean isAssign = n.isAssign();
  Node lhs = null;
  for (Node child = n.getFirstChild();
      child != null; child = child.getNext()) {
    if (isAssign && child == n.getFirstChild()) {
      lhs = child;
      continue; // Skip LHS for now.
    }
    if (!ControlFlowGraph.isEnteringNewCfgNode(child)) {
      VariableLiveness state = isVariableReadBeforeKill(child, variable);
      if (state != VariableLiveness.MAYBE_LIVE) {
        return state;
      }
    }
  }

  // After processing children, if no read, check LHS kill.
  if (isAssign && lhs != null) {
    VariableLiveness state = isVariableReadBeforeKill(lhs, variable);
    if (state == VariableLiveness.KILL) {
      // If LHS is a kill and no read found, propagate kill.
      return VariableLiveness.KILL;
    }
    // Otherwise, propagate whatever state (should be MAYBE_LIVE or READ)
    if (state != VariableLiveness.MAYBE_LIVE) {
      return state;
    }
  }

  return VariableLiveness.MAYBE_LIVE;
}
```

