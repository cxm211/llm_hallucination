public void enterScope(NodeTraversal t) {
    Node declarationRoot = t.getScopeRoot();
    Renamer renamer;
    if (nameStack.isEmpty()) {
      Preconditions.checkState(
          declarationRoot.getType() != Token.FUNCTION ||
          !(rootRenamer instanceof ContextualRenamer));
      Preconditions.checkState(t.inGlobalScope());
      renamer = rootRenamer;
      nameStack.push(renamer);
      return;
    }

    if (declarationRoot.getType() == Token.FUNCTION) {
      // Use the already pushed renamer from shouldTraverse
      renamer = nameStack.peek();
      // Add parameters
      for (Node c = declarationRoot.getFirstChild().getNext().getFirstChild(); c != null; c = c.getNext()) {
        String name = c.getString();
        renamer.addDeclaredName(name);
      }
      // Add body declarations
      Node functionBody = declarationRoot.getLastChild();
      findDeclaredNames(functionBody, null, renamer);
      // No push, as it's already on stack
    } else {
      // Non-function scope: create child scope and push
      renamer = nameStack.peek().forChildScope();
      findDeclaredNames(declarationRoot, null, renamer);
      nameStack.push(renamer);
    }
  }
```

