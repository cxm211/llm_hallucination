    Node fnNode = child;
    if (child.isGetterDef() || child.isSetterDef()) {
      fnNode = child.getFirstChild();
    }
    if (!prop.scheduleRenaming(fnNode,
                               processProperty(t, prop, type, null))) {
      // TODO(user): It doesn't look like the user can do much in this
