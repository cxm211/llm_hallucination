   }\n\n      // Clone any remaining params that aren't in the function literal.\n      while (oldParams.hasNext()) {\n        Node oldParam = oldParams.next();\n        paramBuilder.newParameterFromNode(oldParam);\n      }\n\n      parametersNode = paramBuilder.build();\n    }\n    return this;\n  }",
