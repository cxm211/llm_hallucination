```java
JSType getGreatestSubtypeHelper(JSType that) {
  if (that.isRecordType()) {
    RecordType thatRecord = that.toMaybeRecordType();
    RecordTypeBuilder builder = new RecordTypeBuilder(registry);

    for (String property : properties.keySet()) {
      if (thatRecord.hasProperty(property)) {
        JSType thisPropType = getPropertyType(property);
        JSType thatPropType = thatRecord.getPropertyType(property);
        if (!thisPropType.isSubtype(thatPropType) && !thatPropType.isSubtype(thisPropType)) {
          return registry.getNativeObjectType(JSTypeNative.NO_TYPE);
        }
        // Use the more specific type
        JSType common = thisPropType.isSubtype(thatPropType) ? thisPropType : thatPropType;
        builder.addProperty(property, common, getPropertyNode(property));
      } else {
        builder.addProperty(property, getPropertyType(property), getPropertyNode(property));
      }
    }

    for (String property : thatRecord.properties.keySet()) {
      if (!hasProperty(property)) {
        builder.addProperty(property, thatRecord.getPropertyType(property), thatRecord.getPropertyNode(property));
      }
    }

    return builder.build();
  }

  // rest unchanged
}
```

