// Helper method to check if a node is a descendant of another node.
private boolean isNodeInSubtree(Node ancestor, Node descendant) {
  for (Node current = descendant; current != null; current = current.getParent()) {
    if (current == ancestor) {
      return true;
    }
  }
  return false;
}
