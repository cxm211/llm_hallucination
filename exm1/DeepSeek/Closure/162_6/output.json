    "com.google.javascript.jscomp.LooseTypeCheckTest::testInnerFunction4",
    "com.google.javascript.jscomp.LooseTypeCheckTest::testInnerFunction5",
    "com.google.javascript.jscomp.LooseTypeCheckTest::testInnerFunction9",
