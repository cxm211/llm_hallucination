  public Node optimizeSubtree(Node node) {
    // Preserve FREE_CALL property to avoid breaking wrapping in add()
    if (node.getType() == Token.CALL && node.getBooleanProp(Node.FREE_CALL)) {
      return node;
    }
    switch(node.getType()) {
      case Token.TRUE:
      case Token.FALSE:
        return reduceTrueFalse(node);
      case Token.NEW:
        node = tryFoldStandardConstructors(node);
        if (!node.isCall()) {
          return node;
        }
        // Fall through on purpose
      case Token.CALL:
        Node result = tryFoldLiteralConstructor(node);
        if (result == node) {
          result = tryFoldSimpleFunctionCall(node);
          if (result == node) {
            result = tryFoldImmediateCallToBoundFunction(node);
          }
        }
        return result;
      case Token.RETURN:
        return tryReduceReturn(node);
      case Token.COMMA:
        return trySplitComma(node);
      case Token.NAME:
        return tryReplaceUndefined(node);
      case Token.ARRAYLIT:
        return tryMinimizeArrayLiteral(node);
      default:
        return node;
    }
  }
