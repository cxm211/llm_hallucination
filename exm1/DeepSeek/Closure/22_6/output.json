} else if (parent.getType() != Token.EXPR_RESULT && parent.getType() != Token.BLOCK) {
  if (parent.getType() == Token.FOR && parent.getChildCount() == 4 && (n == parent.getFirstChild() ||
       n == parent.getFirstChild().getNext().getNext())) {
  } else {
    return;
  }
}
```

