    "  public void testGoodExtends11() throws Exception {\n    testTypes(\n        \" function Super() {}\" +\n        \" Super.prototype.foo = function(x) {};\" +\n        \" function Sub() {}\" +\n        \"Sub.prototype = new Super();\" +\n        \"(new Sub()).foo(0);\",\n        \"actual parameter 1 of Super.prototype.foo \" +\n        \"does not match formal parameter\\n\" +\n        \"found   : number\\n\" +\n        \"required: boolean\");\n  }",
