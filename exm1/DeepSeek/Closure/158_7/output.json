    "  public void testAliasedEnum5() throws Exception {\n    testTypes(\n        \" var YourEnum = {FOO: 3};\" +\n        \" var MyEnum = YourEnum;\" +\n        \" function f(x) {} f(MyEnum.FOO);\",\n        \"actual parameter 1 of f does not match formal parameter\\n\" +\n        \"found   : YourEnum.<number>\\n\" +\n        \"required: string\");\n  }",
