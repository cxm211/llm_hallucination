  JSType getGreatestSubtypeHelper(JSType that) {
    if (that.isRecordType()) {
      RecordType thatRecord = that.toMaybeRecordType();
      RecordTypeBuilder builder = new RecordTypeBuilder(registry);
      for (String property : properties.keySet()) {
        if (thatRecord.hasProperty(property)) {
          JSType thisProp = getPropertyType(property);
          JSType thatProp = thatRecord.getPropertyType(property);
          JSType greatestProp = thisProp.getGreatestSubtype(thatProp);
          if (greatestProp.isEmptyType()) {
            return registry.getNativeObjectType(JSTypeNative.NO_TYPE);
          }
          builder.addProperty(property, greatestProp, getPropertyNode(property));
        } else {
          builder.addProperty(property, getPropertyType(property),
              getPropertyNode(property));
        }
      }
      for (String property : thatRecord.properties.keySet()) {
        if (!hasProperty(property)) {
          builder.addProperty(property, thatRecord.getPropertyType(property),
              thatRecord.getPropertyNode(property));
        }
      }
      return builder.build();
    }
    // ... rest unchanged
  }
