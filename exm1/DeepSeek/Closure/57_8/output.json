private static String extractClassNameIfGoog(Node node, Node parent, String functionName) {
  String className = null;
  if (NodeUtil.isAssignmentOp(parent) && parent.getType() == Token.ASSIGN) {
    Node left = parent.getFirstChild();
    if (left != null && left.getType() == Token.GETPROP) {
      String qualifiedName = left.getQualifiedName();
      if (qualifiedName != null && qualifiedName.startsWith("goog.")) {
        // extract the class name after "goog."
        className = qualifiedName.substring(5);
      }
    }
  }
  return className;
}
