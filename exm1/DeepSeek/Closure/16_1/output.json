private void fixTypeNode(Node typeNode) {
  if (typeNode.isString()) {
    String name = typeNode.getString();
    int endIndex = name.indexOf('.');
    if (endIndex == -1) {
      endIndex = name.length();
    }
    String baseName = name.substring(0, endIndex);
    Var aliasVar = aliases.get(baseName);
    if (aliasVar != null) {
      Node aliasedNode = aliasVar.getInitialValue();
      // Resolve chained aliases
      String suffix = (endIndex < name.length()) ? name.substring(endIndex) : "";
      String qualifiedName = resolveAlias(aliasedNode);
      aliasUsages.add(new AliasedTypeNode(typeNode, qualifiedName + suffix));
    }
  }

  for (Node child = typeNode.getFirstChild(); child != null;
       child = child.getNext()) {
    fixTypeNode(child);
  }
}

// Helper method to resolve chained aliases
private String resolveAlias(Node node) {
  if (node.isName()) {
    String name = node.getString();
    Var var = aliases.get(name);
    if (var != null) {
      return resolveAlias(var.getInitialValue());
    }
  }
  return node.getQualifiedName();
}
```

