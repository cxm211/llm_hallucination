public void onRedeclaration(
    Scope s, String name, Node n, Node parent, Node gramps,
    Node nodeWithLineNumber) {
  Preconditions.checkState(n.getType() == Token.NAME);
  Var v = s.getVar(name);
  if (v != null && v.getParentNode().getType() == Token.CATCH) {
    // existing catch variable
    name = MakeDeclaredNamesUnique.ContextualRenameInverter.getOrginalName(name);
    compiler.report(
        JSError.make(
            NodeUtil.getSourceName(nodeWithLineNumber), nodeWithLineNumber,
            CATCH_BLOCK_VAR_ERROR, name));
  } else if (v != null && parent.getType() == Token.FUNCTION) {
    // function declaration redeclaration
    if (v.getParentNode().getType() == Token.VAR) {
      // var was redeclared as function: replace var with assignment
      s.undeclare(v);
      s.declare(name, n, n.getJSType(), v.input);
      replaceVarWithAssignment(v.getNameNode(), v.getParentNode(),
          v.getParentNode().getParent());
    } else if (v.getParentNode().getType() == Token.FUNCTION) {
      // both are function declarations: do nothing (error will be reported elsewhere)
    }
  } else if (parent.getType() == Token.VAR) {
    Preconditions.checkState(parent.hasOneChild());
    // var redeclaration
    if (v != null) {
      replaceVarWithAssignment(n, parent, gramps);
    } else {
      // arguments or something, do nothing
    }
  } else if (v != null && s.isGlobal()) {
    // handle global duplicate like the other handler
    Node origParent = v.getParentNode();
    if (origParent.getType() == Token.CATCH &&
        parent.getType() == Token.CATCH) {
      // both catch, okay
      return;
    }
    boolean allowDupe = false;
    JSDocInfo info = n.getJSDocInfo();
    if (info == null) {
      info = parent.getJSDocInfo();
    }
    allowDupe = info != null && info.getSuppressions().contains("duplicate");
    if (!allowDupe) {
      compiler.report(
          JSError.make(sourceName, n,
                       VAR_MULTIPLY_DECLARED_ERROR,
                       name,
                       (v.input != null ? v.input.getName() : "??")));
    }
  }
}
