```java
private void createSynthesizedExternVar(String varName) {
  // Check if the variable already exists in synthesized externs
  Node externRoot = getSynthesizedExternsRoot();
  for (Node child = externRoot.getFirstChild(); child != null; child = child.getNext()) {
    if (child.getType() == Token.VAR) {
      Node nameNode = child.getFirstChild();
      if (nameNode != null && nameNode.getString().equals(varName)) {
        // Update constant property if needed
        if (compiler.getCodingConvention().isConstant(varName)) {
          nameNode.putBooleanProp(Node.IS_CONSTANT_NAME, true);
        }
        return;
      }
    }
  }
  // else create new
  Node nameNode = Node.newString(Token.NAME, varName);
  if (compiler.getCodingConvention().isConstant(varName)) {
    nameNode.putBooleanProp(Node.IS_CONSTANT_NAME, true);
  }
  externRoot.addChildToBack(new Node(Token.VAR, nameNode));
  varsToDeclareInExterns.remove(varName);
}
```

