  }
  if (parent != null && parent.shouldKeepKeys()) {
    return false;
  }
  if (type != Type.FUNCTION && aliasingGets > 0) {
    return false;
  }
  return (parent == null || parent.canCollapseUnannotatedChildNames());
}
```

