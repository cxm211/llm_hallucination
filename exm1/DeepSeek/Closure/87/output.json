private boolean isFoldableExpressBlock(Node n) {
    if (n.getType() == Token.BLOCK) {
      if (n.hasOneChild()) {
        Node maybeExpr = n.getFirstChild();
        if (NodeUtil.isExpressionNode(maybeExpr)) {
          // Check if this expression is a call to a property that might be an event handler
          Node expr = maybeExpr.getFirstChild();
          if (expr != null && expr.getType() == Token.CALL) {
            Node callee = expr.getFirstChild();
            if (callee != null && (callee.getType() == Token.GETPROP || callee.getType() == Token.GETELEM)) {
              // If it's a GETPROP, check if property name starts with 'on' (event handler)
              // If it's a GETELEM, always avoid folding because property name is unknown
              if (callee.getType() == Token.GETELEM) {
                return false;
              }
              if (callee.getType() == Token.GETPROP) {
                String propName = callee.getLastChild().getString();
                // Event handler properties typically start with 'on'
                if (propName.startsWith("on")) {
                  return false;
                }
              }
            }
          }
          return true;
        }
      }
    }
    return false;
  }

