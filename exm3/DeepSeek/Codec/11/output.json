public static final byte[] encodeQuotedPrintable(BitSet printable, byte[] bytes) {
    if (bytes == null) {
        return null;
    }
    if (printable == null) {
        printable = PRINTABLE_CHARS; // assume defined elsewhere
    }
    ByteArrayOutputStream buffer = new ByteArrayOutputStream();
    final int MAX_LINE_LENGTH = 76;
    int lineLength = 0;
    for (int i = 0; i < bytes.length; i++) {
        int b = bytes[i] & 0xFF;
        boolean isPrintable = printable.get(b);
        boolean isWhitespace = (b == 32 || b == 9); // space or tab
        boolean needEncode = false;
        int encodedLen = 1;
        
        if (!isPrintable) {
            needEncode = true;
            encodedLen = 3;
        } else if (isWhitespace) {
            // Check if this whitespace is at the end of a line
            if (i == bytes.length - 1) {
                needEncode = true;
            } else {
                // Look ahead to the next byte
                int nextB = bytes[i+1] & 0xFF;
                boolean nextPrintable = printable.get(nextB);
                int nextLen = 1;
                if (!nextPrintable) {
                    nextLen = 3;
                } else if (nextB == 32 || nextB == 9) {
                    // For next whitespace, we assume it will not be encoded for this lookahead.
                    // This is a simplification.
                    nextLen = 1;
                }
                if (lineLength + 1 + nextLen > MAX_LINE_LENGTH) {
                    needEncode = true;
                }
            }
            if (needEncode) {
                encodedLen = 3;
            }
        } else {
            // printable non-whitespace
            needEncode = false;
            encodedLen = 1;
        }
        
        // Check if we need to insert a soft line break before this character
        if (lineLength + encodedLen > MAX_LINE_LENGTH) {
            buffer.write(ESCAPE_CHAR);
            buffer.write('\r');
            buffer.write('\n');
            lineLength = 0;
        }
        
        if (needEncode) {
            encodeQuotedPrintable(b, buffer);
        } else {
            buffer.write(b);
        }
        lineLength += encodedLen;
    }
    return buffer.toByteArray();
}

Now, decode function:

public static final byte[] decodeQuotedPrintable(byte[] bytes) throws DecoderException {
    if (bytes == null) {
        return null;
    }
    ByteArrayOutputStream buffer = new ByteArrayOutputStream();
    for (int i = 0; i < bytes.length; i++) {
        final int b = bytes[i];
        if (b == ESCAPE_CHAR) {
            // Check for soft line break
            if (i + 2 < bytes.length && bytes[i+1] == '\r' && bytes[i+2] == '\n') {
                i += 2; // skip CR and LF, the for loop will increment i by 1 more, so total +3
                continue;
            }
            // Otherwise, decode hex sequence
            if (i + 2 >= bytes.length) {
                throw new DecoderException("Invalid quoted-printable encoding");
            }
            try {
                int u = Utils.digit16(bytes[++i]);
                int l = Utils.digit16(bytes[++i]);
                buffer.write((char) ((u << 4) + l));
            } catch (ArrayIndexOutOfBoundsException e) {
                throw new DecoderException("Invalid quoted-printable encoding", e);
            }
        } else {
            // Skip CR and LF
            if (b != '\r' && b != '\n') {
                buffer.write(b);
            }
        }
    }
    return buffer.toByteArray();
}

Note: In the soft line break case, we need to skip the CR and LF. We do i+=2 and then continue; the for loop will increment i by 1, so total i increases by 3. Good.

