public OngoingInjecter filterCandidate(Collection<Object> mocks, Field field, Object fieldInstance) {
    if (mocks.size() == 1) {
        // if there's only one mock, check if its name matches the field
        Object onlyMock = mocks.iterator().next();
        if (nameMatches(field, onlyMock)) {
            return new OngoingInjecter() { ... };
        }
    } else {
        // iterate over mocks and find one with matching name
        for (Object mock : mocks) {
            if (nameMatches(field, mock)) {
                return new OngoingInjecter() { ... };
            }
        }
    }
    return new OngoingInjecter() { ... }; // no match
}

