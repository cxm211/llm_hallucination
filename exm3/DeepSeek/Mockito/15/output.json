    public OngoingInjecter filterCandidate(final Collection<Object> mocks, final Field field, final Object fieldInstance) {
        if (mocks.size() == 1) {
            final Object onlyMock = mocks.iterator().next();
            if (nameMatches(field, onlyMock)) {
                return createInjecter(fieldInstance, field, onlyMock);
            }
        } else {
            for (Object mock : mocks) {
                if (nameMatches(field, mock)) {
                    return createInjecter(fieldInstance, field, mock);
                }
            }
        }
        return new OngoingInjecter() {
            public boolean thenInject() {
                return false;
            }
        };
    }

    private OngoingInjecter createInjecter(final Object fieldInstance, final Field field, final Object mock) {
        return new OngoingInjecter() {
            public boolean thenInject() {
                try {
                    new org.mockito.internal.util.reflection.PropertySetter(fieldInstance, field).set(mock);
                } catch (Exception e) {
                    throw new MockitoException("Problems injecting dependency in " + field.getName(), e);
                }
                return true;
            }
        };
    }
```

