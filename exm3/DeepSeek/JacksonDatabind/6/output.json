String normalizeTime(String time) {
    int dotIndex = time.indexOf('.');
    if (dotIndex >= 0) {
        String beforeDot = time.substring(0, dotIndex);
        String millis = time.substring(dotIndex+1);
        if (millis.length() < 3) {
            // pad right with zeros
            while (millis.length() < 3) millis += "0";
        } else if (millis.length() > 3) {
            // keep as is, assuming format can handle
        }
        time = beforeDot + "." + millis;
        // Now ensure that beforeDot has proper colons for seconds.
        // beforeDot could be HH, HH:mm, or HH:mm:ss.
        // We need to ensure it has two colons.
        int colons = countColons(beforeDot);
        if (colons == 0) {
            beforeDot = beforeDot + ":00:00";
        } else if (colons == 1) {
            beforeDot = beforeDot + ":00";
        }
        // if colons == 2, it's fine.
        time = beforeDot + "." + millis;
    } else {
        int colons = countColons(time);
        if (colons == 0) {
            time = time + ":00:00.000";
        } else if (colons == 1) {
            time = time + ":00.000";
        } else if (colons == 2) {
            time = time + ".000";
        }
    }
    return time;
}

