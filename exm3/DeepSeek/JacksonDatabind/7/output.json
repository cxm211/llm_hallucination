    assertToken(JsonToken.VALUE_NUMBER_INT, tbParser.nextToken());
    assertEquals(1, tbParser.getIntValue());
    assertToken(JsonToken.END_OBJECT, tbParser.nextToken());
    tbParser.close();
    jp.close();
}

