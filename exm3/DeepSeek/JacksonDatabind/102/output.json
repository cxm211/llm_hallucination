        .setFormat(JsonFormat.Value.forShape(JsonFormat.Shape.STRING));
    // Serialize a date; should use the pattern above
    assertEquals("\"2020/01/01\"",
        mapper.writeValueAsString(java.sql.Date.valueOf("2020-01-01")));
}
```

