public void testRemoveCaseInsensitiveProperty() throws Exception
{
    ObjectMapper mapper = new ObjectMapper();
    mapper.enable(MapperFeature.ACCEPT_CASE_INSENSITIVE_PROPERTIES);
    
    // Define a simple bean with mixed case property
    mapper.readValue("{}", SimpleBeanWithMixedCase.class); // ensure deserializer is constructed
    JavaType type = mapper.constructType(SimpleBeanWithMixedCase.class);
    JsonDeserializer<Object> deser = mapper.getDeserializerProvider().findValueDeserializer(mapper.getDeserializationConfig(), type, null);
    BeanDeserializer beanDeser = (BeanDeserializer) deser;
    // Use reflection to get _propertyMap
    Field f = BeanDeserializer.class.getDeclaredField("_propertyMap");
    f.setAccessible(true);
    BeanPropertyMap propertyMap = (BeanPropertyMap) f.get(beanDeser);
    
    // Find property by lower-cased name
    SettableBeanProperty prop = propertyMap.find("fullname");
    assertNotNull(prop);
    // The property's getName() returns "FullName" (original case)
    assertEquals("FullName", prop.getName());
    
    // Remove the property
    propertyMap.remove(prop);
    
    // Verify it's removed
    assertNull(propertyMap.find("fullname"));
}
```

