    assertTrue(iter2.hasNext());
    CSVRecord record = iter2.next();
    assertEquals("1", record.get(0));
    // Continue to ensure sequence
    assertTrue(iter2.hasNext());
    record = iter2.next();
    assertEquals("2", record.get(0));
    assertTrue(iter2.hasNext());
    record = iter2.next();
    assertEquals("3", record.get(0));
    assertFalse(iter2.hasNext());
}

