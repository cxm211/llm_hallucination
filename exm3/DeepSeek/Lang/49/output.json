public Fraction reduce() {
    if (numerator == 0) {
        return Fraction.ZERO;
    }
    // Use long for safe absolute values and gcd
    long a = numerator;
    long b = denominator;
    long absA = a < 0 ? -a : a;
    long absB = b < 0 ? -b : b;
    // compute gcd of absA and absB
    long gcd = absA;
    long temp = absB;
    while (temp != 0) {
        long remainder = gcd % temp;
        gcd = temp;
        temp = remainder;
    }
    // gcd is positive (or zero if both zero, but denominator != 0)
    // Divide original a and b by gcd
    long newNum = a / gcd;
    long newDen = b / gcd;
    // Ensure denominator positive
    if (newDen < 0) {
        newNum = -newNum;
        newDen = -newDen;
    }
    // Check if the result is equal to the current fraction
    // But note: a and b are original numerator and denominator as long.
    // We need to compare with original ints. However, since we performed division by gcd,
    // newNum and newDen are longs but should fit into int.
    int intNum = (int) newNum;
    int intDen = (int) newDen;
    if (intNum == numerator && intDen == denominator) {
        return this;
    }
    return Fraction.getFraction(intNum, intDen);
}

