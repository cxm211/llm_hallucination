public Fraction reduce() {
    if (numerator == 0) {
        return Fraction.ZERO;
    }
    // Use long to avoid overflow in absolute value and gcd computation
    long a = numerator;
    long b = denominator;
    long absA = a < 0 ? -a : a;
    long absB = b < 0 ? -b : b;
    // compute gcd using Euclidean algorithm
    long gcd = absA;
    long temp = absB;
    while (temp != 0) {
        long remainder = gcd % temp;
        gcd = temp;
        temp = remainder;
    }
    // divide original numbers by gcd
    long newNum = a / gcd;
    long newDen = b / gcd;
    // ensure denominator positive
    if (newDen < 0) {
        newNum = -newNum;
        newDen = -newDen;
    }
    int intNum = (int) newNum;
    int intDen = (int) newDen;
    if (intNum == numerator && intDen == denominator) {
        return this;
    }
    return Fraction.getFraction(intNum, intDen);
}

