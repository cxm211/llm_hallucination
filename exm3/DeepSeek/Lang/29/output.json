    public static float toJavaVersionInt(String version) {
        return toVersionInt(toJavaVersionIntArray(version, JAVA_VERSION_TRIM_SIZE));
    }

    private static float toVersionInt(int[] versionBits) {
        if (versionBits == null || versionBits.length == 0) {
            return 0f;
        }
        int mult = 100;
        float ver = 0;
        for (int i = 0; i < versionBits.length; i++) {
            ver += versionBits[i] * mult;
            mult /= 10;
        }
        return ver;
    }

    private static int[] toJavaVersionIntArray(String version, int trimSize) {
        if (version == null) {
            return ArrayUtils.EMPTY_INT_ARRAY;
        }
        String[] split = version.split("[^0-9]+");
        List<Integer> list = new ArrayList<>();
        for (String s : split) {
            if (s.length() > 0) {
                list.add(Integer.parseInt(s));
            }
        }
        if (list.size() > trimSize) {
            list = list.subList(0, trimSize);
        }
        int[] array = new int[list.size()];
        for (int i = 0; i < list.size(); i++) {
            array[i] = list.get(i);
        }
        return array;
    }

