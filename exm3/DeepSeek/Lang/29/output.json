    static float toJavaVersionInt(String version) {
        if (version == null) {
            return 0f;
        }
        java.util.regex.Pattern p = java.util.regex.Pattern.compile("\\d+");
        java.util.regex.Matcher m = p.matcher(version);
        int[] vers = new int[3];
        int i = 0;
        while (m.find() && i < 3) {
            vers[i++] = Integer.parseInt(m.group());
        }
        if (i == 0) {
            return 0f;
        }
        int major = vers[0];
        int minor = (i > 1) ? vers[1] : 0;
        int patch = (i > 2) ? vers[2] : 0;
        return (float) (major * 100 + minor * 10 + patch);
    }

