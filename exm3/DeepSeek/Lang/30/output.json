                if (searchChars[j] == high && searchChars[j + 1] == low) {
                    return true;
                }
            }
            i++; // skip the low surrogate
        } else {
            // BMP or lone surrogate
            for (int j = 0; j < searchLength; j++) {
                if (searchChars[j] == ch) {
                    return true;
                }
            }
        }
    }
    return false;
}
