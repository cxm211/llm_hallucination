        return true; // GNU tar format
    }
    // old style tar
    long sum = 0;
    long signedSum = 0;
    // compute checksum
    for (int i = 0; i < 148; i++) {
        sum += 0xff & signature[i];
        signedSum += signature[i];
    }
    for (int i = 148; i < 156; i++) {
        sum += ' ';
        signedSum += ' ';
    }
    for (int i = 156; i < 512; i++) {
        sum += 0xff & signature[i];
        signedSum += signature[i];
    }
    long storedSum = 0;
