@Test
public void testVerifyCheckSumWithSpaceInChecksumField() {
    // create a header with all zeros, set checksum field with space in middle
    byte[] header = new byte[512];
    // fill with zeros already
    int offset = 148; // CHKSUM_OFFSET
    // set checksum field bytes
    header[offset]   = '0';
    header[offset+1] = '0';
    header[offset+2] = '0';
    header[offset+3] = ' ';
    header[offset+4] = '4';
    header[offset+5] = '0';
    header[offset+6] = '0';
    header[offset+7] = ' ';
    // compute expected checksum: 8 spaces = 256, rest zeros, so unsigned sum = 256.
    // The stored sum should be octal 000400 = 256.
    // With buggy code, verification fails; with fixed code, passes.
