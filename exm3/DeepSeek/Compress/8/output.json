public static long parseOctal(final byte[] buffer, final int offset, final int length) {
    if (length < 2) {
        throw new IllegalArgumentException(
            exceptionMessage(buffer, offset, length, offset, (byte)0));
    }
    long result = 0;
    int i = offset;
    int end = offset + length;
    
    // Skip leading spaces
    while (i < end && buffer[i] == ' ') {
        i++;
    }
    
    // Check if there is at least one digit
    if (i == end || buffer[i] < '0' || buffer[i] > '7') {
        throw new IllegalArgumentException(
            exceptionMessage(buffer, offset, length, offset, buffer[i]));
    }
    
    // Parse digits
    while (i < end && buffer[i] >= '0' && buffer[i] <= '7') {
        result = (result << 3) + (buffer[i] - '0');
        i++;
    }
    
    // After digits, we must have a terminator
    if (i == end || !(buffer[i] == 0 || buffer[i] == ' ')) {
        throw new IllegalArgumentException(
            exceptionMessage(buffer, offset, length, offset, buffer[i]));
    }
    
    // Check that the rest are terminators
    while (i < end) {
        if (!(buffer[i] == 0 || buffer[i] == ' ')) {
            throw new IllegalArgumentException(
                exceptionMessage(buffer, offset, length, offset, buffer[i]));
        }
        i++;
    }
    
    return result;
}

