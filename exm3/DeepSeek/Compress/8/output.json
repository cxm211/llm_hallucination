public static long parseOctal(final byte[] buffer, final int offset, final int length) {
    if (length < 2) {
        throw new IllegalArgumentException("length must be at least 2"); // or use exceptionMessage
    }
    long result = 0;
    int i = offset;
    int end = offset + length;
    
    // Skip leading spaces and zeros
    while (i < end && (buffer[i] == ' ' || buffer[i] == '0')) {
        i++;
    }
    
    // Now, we must have at least one digit
    if (i == end || buffer[i] < '0' || buffer[i] > '7') {
        throw new IllegalArgumentException(...);
    }
    
    // Parse digits
    while (i < end && buffer[i] >= '0' && buffer[i] <= '7') {
        result = (result << 3) + (buffer[i] - '0');
        i++;
    }
    
    // After digits, we must have at least one terminator
    if (i == end || !(buffer[i] == 0 || buffer[i] == ' ')) {
        throw new IllegalArgumentException(...);
    }
    
    // Now, check that the rest are terminators
    while (i < end) {
        if (!(buffer[i] == 0 || buffer[i] == ' ')) {
            throw new IllegalArgumentException(...);
        }
        i++;
    }
    
    return result;
}

