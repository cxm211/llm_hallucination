public void testCloneIndependence() {
    TimeSeries s1 = new TimeSeries("Series1");
    s1.add(new Day(1, 1, 2007), 100.0); // add an item
    TimeSeries s2 = null;
    try {
        s2 = (TimeSeries) s1.clone();
    } catch (CloneNotSupportedException e) {
        e.printStackTrace();
    }
    assertTrue(s1 != s2);
    assertTrue(s1.equals(s2));
    // modify the clone
    s2.add(new Day(2, 1, 2007), 200.0);
    assertFalse(s1.equals(s2)); // should be different now
}

