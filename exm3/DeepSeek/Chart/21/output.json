                Number maxOutlier = item.getMaxOutlier();
                double minVal = Double.NaN;
                double maxVal = Double.NaN;
                if (minOutlier != null) {
                    minVal = minOutlier.doubleValue();
                }
                if (maxOutlier != null) {
                    maxVal = maxOutlier.doubleValue();
                }
                if (!Double.isNaN(minVal)) {
