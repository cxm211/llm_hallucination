@Test
public void testEscapeWhitespace() throws Exception {
    // Get the escape method
    Class<?> entitiesClass = Class.forName("org.jsoup.nodes.Entities");
    Method escapeMethod = entitiesClass.getDeclaredMethod("escape", StringBuilder.class, String.class,
            Document.OutputSettings.class, boolean.class, boolean.class, boolean.class);
    escapeMethod.setAccessible(true);
    
    // Helper to call escape and return string
    java.util.function.Function<Object[], String> callEscape = params -> {
        StringBuilder accum = new StringBuilder();
        try {
            escapeMethod.invoke(null, accum, (String)params[0], (Document.OutputSettings)params[1],
                    (boolean)params[2], (boolean)params[3], (boolean)params[4]);
        } catch (Exception e) {
            throw new RuntimeException(e);
        }
        return accum.toString();
    };
    
    // Create output settings with base escape mode and UTF-8 charset (encodes everything)
    Document.OutputSettings out = new Document.OutputSettings();
    out.escapeMode(Entities.EscapeMode.base);
    out.charset(StandardCharsets.UTF_8);
    
    // Test normaliseWhite = true, stripLeadingWhite = false
    String input1 = "  a  b  c  ";
    String result1 = callEscape.apply(new Object[]{input1, out, false, true, false});
    // Expect spaces collapsed to single spaces, leading/trailing spaces? With stripLeadingWhite false, leading spaces should be collapsed to one space? Actually, the first two spaces: first space triggers append(' ') and lastWasWhite=true, second space skips because lastWasWhite true. So we get one space. Then 'a' (non-white), then two spaces: first space after non-white: lastWasWhite is false, so append space and set lastWasWhite true, second space skips. So result should be " a b c " (single spaces between words, and leading/trailing spaces? The leading spaces: first space appended? Since stripLeadingWhite false and reachedNonWhite false, the first whitespace will not be skipped because lastWasWhite is false and stripLeadingWhite false, so we append a space. So leading space becomes one space. Similarly, trailing spaces: after 'c', there are two spaces. The first space: lastWasWhite false (since previous char 'c' non-white), so append space and set lastWasWhite true. The second space: lastWasWhite true, so skip. So trailing space remains one space. So overall: " a b c ". But note that there is also a space before 'a', between 'a' and 'b', between 'b' and 'c', and after 'c'. So " a b c ". That's correct.
    assertEquals(" a b c ", result1);
    
    // Test normaliseWhite = true, stripLeadingWhite = true
    String input2 = "  a  b  c  ";
    String result2 = callEscape.apply(new Object[]{input2, out, false, true, true});
    // Leading whitespace should be skipped until first non-white. So no leading space. Result: "a b c " (trailing space remains because trailing spaces are not stripped).
    // Let's compute: first two spaces: stripLeadingWhite true and reachedNonWhite false, so skip. Then 'a' (set reachedNonWhite true, lastWasWhite false). Then two spaces: first space: lastWasWhite false, so append space and set lastWasWhite true; second space: lastWasWhite true, skip. Then 'b', then spaces, then 'c', then two spaces: first space after c: append space, second skip. So result: "a b c ".
    assertEquals("a b c ", result2);
    
    // Test normaliseWhite = false
    String input3 = "  a  b  c  ";
    String result3 = callEscape.apply(new Object[]{input3, out, false, false, false});
    // Should not modify whitespace, so output same as input.
    assertEquals(input3, result3);
    
    // Also include a bug check to ensure test fails on buggy version: 0xA0 in xhtml with Shift_JIS
    Document.OutputSettings out2 = new Document.OutputSettings();
    out2.escapeMode(Entities.EscapeMode.xhtml);
    out2.charset(Charset.forName("Shift_JIS"));
    String input4 = "\u00A0";
    String result4 = callEscape.apply(new Object[]{input4, out2, false, false, false});
    // Should not contain '?'
    assertFalse(result4.contains("?"));
    // Should contain &#xa0; or &nbsp;
    assertTrue(result4.contains("&#xa0;") || result4.contains("&nbsp;"));
}
