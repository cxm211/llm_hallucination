@Test
public void testEscapeVarious() throws Exception {
    // Test 1: 0xA0 in xhtml with Shift_JIS (non-encodable) - bug case
    String input = "<html><body>before&#xa0;after</body></html>";
    InputStream is = new ByteArrayInputStream(input.getBytes(StandardCharsets.UTF_8));
    Document doc = Jsoup.parse(is, null, "http://example.com");
    doc.outputSettings().escapeMode(Entities.EscapeMode.xhtml);
    doc.outputSettings().charset(Charset.forName("Shift_JIS"));
    String output = doc.html();
    assertFalse("Should not contain '?'", output.contains("?"));
    assertTrue("Should contain &#xa0; or &nbsp;", output.contains("&#xa0;") || output.contains("&nbsp;"));
    
    // Test 2: attribute escaping with base escape mode
    Document doc2 = Jsoup.parse("<div></div>");
    doc2.outputSettings().escapeMode(Entities.EscapeMode.base);
    Element div = doc2.select("div").first();
    div.attr("test", "a & b < c > d \" e");
    String attrHtml = div.attributes().get("test").html();
    assertTrue(attrHtml.contains("&amp;"));
    assertTrue(attrHtml.contains("<")); // not escaped in attribute
    assertTrue(attrHtml.contains(">")); // not escaped in attribute
    assertTrue(attrHtml.contains("&quot;"));
    
    // Test 3: text node escaping with xhtml and UTF-8 (encodable non-breaking space)
    Document doc3 = Jsoup.parse("<div></div>");
    doc3.outputSettings().escapeMode(Entities.EscapeMode.xhtml);
    doc3.outputSettings().charset(StandardCharsets.UTF_8);
    Element body3 = doc3.body();
    body3.text("\u00A0"); // set text content (non-breaking space)
    String html3 = body3.html();
    assertEquals("\u00A0", html3);
    
    // Test 4: supplementary character with ASCII charset (cannot encode)
    Document doc4 = Jsoup.parse("<div></div>");
    doc4.outputSettings().escapeMode(Entities.EscapeMode.base);
    doc4.outputSettings().charset(StandardCharsets.US_ASCII);
    Element body4 = doc4.body();
    body4.text("\uD83D\uDE00"); // grinning face emoji
    String html4 = body4.html();
    assertTrue("Should contain numeric entity for emoji", html4.contains("&#x1f600;") || html4.contains("&#x1F600;"));
    
    // Test 5: escape mode extended, character that has named entity (e.g., copyright symbol)
    // The extended escape mode includes many named entities. We'll test with '©' (0xA9)
    Document doc5 = Jsoup.parse("<div></div>");
    doc5.outputSettings().escapeMode(Entities.EscapeMode.extended);
    doc5.outputSettings().charset(StandardCharsets.UTF_8);
    Element body5 = doc5.body();
    body5.text("\u00A9"); // copyright symbol
    String html5 = body5.html();
    // Should output &copy; or raw character? According to the escape function, if map contains it, it will output named entity.
    // The extended map includes &copy; for copyright.
    assertTrue(html5.equals("&copy;") || html5.equals("\u00A9"));
    // Actually, since UTF-8 can encode it, and map contains it, the default branch will use map because map.containsKey is true before canEncode? Wait, order: first canEncode, if true, append c. So if canEncode returns true, it will output raw character. So it may output raw character. That's fine.
    // We'll just ensure no '?'.
    assertFalse(html5.contains("?"));
}
