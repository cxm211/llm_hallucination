@Test

public void namespaceScoping() throws IOException {

    String html = "<root><inner xmlns:b='http://example.com/b'><b:item>text</b:item></inner><outer>no prefix</outer></root>";

    org.jsoup.nodes.Document jsoupDoc = Jsoup.parse(html, "", org.jsoup.parser.Parser.xmlParser());

    Document w3cDoc = new W3CDom().fromJsoup(jsoupDoc);

    // Now check namespaces

    Node root = w3cDoc.getDocumentElement();

    assertEquals("root", root.getLocalName());

    // inner should have namespace for b defined, but only for its children

    Node inner = root.getFirstChild();

    assertEquals("inner", inner.getLocalName());

    // inner itself does not have a prefix, so no namespace for inner? Actually, inner is an element without prefix, so namespace should be null or default.

    // Check child of inner

    Node item = inner.getFirstChild();

    assertEquals("item", item.getLocalName());

    assertEquals("http://example.com/b", item.getNamespaceURI());

    // Now outer should not have namespace b

    Node outer = inner.getNextSibling();

    assertEquals("outer", outer.getLocalName());

    assertNull(outer.getNamespaceURI()); // since no default namespace

}

