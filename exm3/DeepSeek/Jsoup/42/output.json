    {
      "path": "org/jsoup/nodes/FormElementTest.java",
      "testcase": "@Test public void multipleSelectWithNoSelectedOptions() {\n        String html = \"<form><select name='foo' multiple><option value='a'>A</option><option value='b'>B</option></select></form>\";\n        Document doc = Jsoup.parse(html);\n        FormElement form = (FormElement) doc.select(\"form\").first();\n        List<Connection.KeyVal> data = form.formData();\n        assertEquals(0, data.size());\n    }"
    }
