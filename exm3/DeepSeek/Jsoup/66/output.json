    // Verify parent pointers
    assertEquals(originalDiv, originalB.parent().parent()); // b -> p -> div
    assertEquals(clonedDiv, clonedB.parent().parent());
    // Add a new child to cloned div
    clonedDiv.append("<span>new</span>");
    assertEquals(3, clonedDiv.childNodeSize()); // originally 2 children (p and text), now 3
    assertEquals(2, originalDiv.childNodeSize()); // original unchanged
}
