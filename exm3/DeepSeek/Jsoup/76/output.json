      "testcase": "@Test public void listingSkipsFirstNewline() {\n        Document doc = Jsoup.parse(\"<listing>\\n\\nOne\\nTwo\\n</listing>\");\n        Element listing = doc.selectFirst(\"listing\");\n        assertEquals(\"One\\nTwo\", listing.text());\n        assertEquals(\"\\nOne\\nTwo\\n\", listing.wholeText());\n    }"
    },
