      "path": "com/google/javascript/jscomp/RuntimeTypeCheckTest.java",
      "testcase": "public void testValueWithMultipleInnerFns() {\n    testChecks(\"/** @param {string} s */ function f(s) { function g() {} function h() {} }\",\n        \"function f(s) {\" +\n        \"  function g() {}\" +\n        \"  function h() {}\" +\n        \"  jscomp.typecheck.checkType(s, \" +\n        \"      [jscomp.typecheck.valueChecker('string')]);\" +\n        \"}\");\n  }"
