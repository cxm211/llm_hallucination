      "testcase": "public void testPrintInOperatorInForLoopMultipleVar() {\n    assertPrint(\"var a={}; for (var i = 0, j = (\\\"length\\\" in a); i;) {}\",\n        \"var a={};for(var i=0,j=(\\\"length\\\"in a);i;);\");\n}"
