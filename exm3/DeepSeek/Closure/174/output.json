```
  private void findAliases(NodeTraversal t) {
    Scope scope = t.getScope();
    for (Var v : scope.getVarIterable()) {
      Node n = v.getNode();
      Node parent = n.getParent();
      if (v.isBleedingFunction()) {
        // Bleeding functions already get a BAD_PARAMETERS error, so just
        // do nothing.
        continue;
      }
      if (parent.getType() == Token.LP) {
        // Parameters of the scope function also get a BAD_PARAMETERS
        // error.
        continue;
      }
      if (parent.isVar()) {
        boolean hasAssignment = n.hasChildren();
        if (hasAssignment) {
          Node value = n.getFirstChild();
          if (value.isQualifiedName()) {
            recordAlias(v);
          } else {
            // Transform scope variable with assignment.
            Node detachedValue = value.detachFromParent();
            String name = n.getString();
            int nameCount = scopedAliasNames.count(name);
            scopedAliasNames.add(name);
            String globalName =
                "$jscomp.scope." + name + (nameCount == 0 ? "" : ("$" + nameCount));

            compiler.ensureLibraryInjected("base");

            // Add $jscomp.scope.name = EXPR;
            // Make sure we copy over all the jsdoc and debug info.
            Node newDecl = NodeUtil.newQualifiedNameNodeDeclaration(
                compiler.getCodingConvention(),
                globalName,
                detachedValue,
                v.getJSDocInfo())
                .useSourceInfoIfMissingFromForTree(n);
            NodeUtil.setDebugInformation(
                newDecl.getFirstChild().getFirstChild(), n, name);
            parent.getParent().addChildBefore(newDecl, parent);

            // Rewrite "var name = EXPR;" to "var name = $jscomp.scope.name;"
            v.getNameNode().addChildToFront(
                NodeUtil.newQualifiedNameNode(
                    compiler.getCodingConvention(), globalName, n, name));

            recordAlias(v);
          }
        } else {
          // Variable declared without assignment.
          String name = n.getString();
          int nameCount = scopedAliasNames.count(name);
          scopedAliasNames.add(name);
          String globalName =
              "$jscomp.scope." + name + (nameCount == 0 ? "" : ("$" + nameCount));

          compiler.ensureLibraryInjected("base");

          // If there is JSDoc, create a statement with just the global name.
          JSDocInfo jsdoc = v.getJSDocInfo();
          if (jsdoc != null) {
            Node nameNode = NodeUtil.newQualifiedNameNode(
                compiler.getCodingConvention(), globalName);
            Node expr = IR.exprResult(nameNode).useSourceInfoIfMissingFromForTree(n);
            expr.setJSDocInfo(jsdoc);
            NodeUtil.setDebugInformation(nameNode, n, name);
            parent.getParent().addChildBefore(expr, parent);
          }

          // Rewrite "var name;" to "var name = $jscomp.scope.name;"
          v.getNameNode().addChildToFront(
              NodeUtil.newQualifiedNameNode(
                  compiler.getCodingConvention(), globalName, n, name));

          recordAlias(v);
        }
      } else {
        // Do not allow hoisted functions or other kinds of local symbols.
        report(t, n, GOOG_SCOPE_NON_ALIAS_LOCAL, n.getString());
      }
    }
  }
```

