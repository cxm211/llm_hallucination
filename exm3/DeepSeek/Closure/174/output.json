```
private void findAliases(NodeTraversal t) {
  Scope scope = t.getScope();
  for (Var v : scope.getVarIterable()) {
    Node n = v.getNode();
    Node parent = n.getParent();
    if (v.isBleedingFunction()) {
      // Bleeding functions already get a BAD_PARAMETERS error, so just
      // do nothing.
      continue;
    }
    if (parent.getType() == Token.LP) {
      // Parameters of the scope function also get a BAD_PARAMETERS
      // error.
      continue;
    }
    if (parent.isVar()) {
      boolean hasAssignment = n.hasChildren();
      if (hasAssignment) {
        Node value = n.getFirstChild();
        if (value.isQualifiedName()) {
          recordAlias(v);
        } else {
          // Transform scope variable with assignment
          transformScopeVariableWithAssignment(v, n, parent, value);
        }
      } else {
        // Variable declared without assignment.
        // This is a scope variable without initialization.
        transformScopeVariableWithoutAssignment(v, n, parent);
      }
    } else {
      // Do not allow hoisted functions or other kinds of local symbols.
      report(t, n, GOOG_SCOPE_NON_ALIAS_LOCAL, n.getString());
    }
  }
}
```

