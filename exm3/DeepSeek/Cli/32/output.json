protected int findWrapPos(String text, int width, int startPos)
{
    int pos;
    
    // look for newline, carriage return or tab within the wrap limit
    if (((pos = text.indexOf('\n', startPos)) != -1 && pos <= startPos + width)
            || ((pos = text.indexOf('\r', startPos)) != -1 && pos <= startPos + width)
            || ((pos = text.indexOf('\t', startPos)) != -1 && pos <= startPos + width))
    {
        return pos + 1;
    }
    else if (startPos + width >= text.length())
    {
        return -1;
    }

    // look for the last whitespace character before startPos+width
    pos = startPos + width;

    char c;

    while ((pos >= startPos) && ((c = text.charAt(pos)) != ' ')
            && (c != '\n') && (c != '\r') && (c != '\t'))
    {
        --pos;
    }

    // if we found it - just return
    if (pos > startPos)
    {
        return pos;
    }
    
    // if we didn't find one, simply chop at startPos+width
    return startPos + width;
}

Note: We removed the second while loop and the final ternary. Also added carriage return and tab to the first condition, and tab to the while condition.

