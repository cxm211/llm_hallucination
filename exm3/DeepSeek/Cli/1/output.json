    assertTrue(commandLine.hasOption("-d"));
    assertTrue(commandLine.hasOption("d"));
    assertTrue(commandLine.hasOption("debug"));
    assertEquals("true", commandLine.getOptionValue("-d"));
    assertEquals("true", commandLine.getOptionValue("d"));
}
