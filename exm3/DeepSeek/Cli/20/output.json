    protected String[] flatten(Options options, String[] arguments, boolean stopAtNonOption)
    {
        init();
        this.options = options;

        // an iterator for the command line tokens
        Iterator iter = Arrays.asList(arguments).iterator();

        // process each command line token
        while (iter.hasNext())
        {
            // get the next command line token
            String token = (String) iter.next();

            if (stopAtNonOption)
            {
                process(token);
            }
            else
            {
                // handle long option --foo or --foo=bar
                if (token.startsWith("--"))
                {
                    if (token.indexOf('=') != -1)
                    {
                        tokens.add(token.substring(0, token.indexOf('=')));
                        tokens.add(token.substring(token.indexOf('=') + 1, token.length()));
                    }
                    else
                    {
                        tokens.add(token);
                    }
                }

                // single hyphen
                else if ("-".equals(token))
                {
                    tokens.add(token);
                }
                else if (token.startsWith("-"))
                {
                    if (token.length() == 2)
                    {
                        processOptionToken(token, stopAtNonOption);
                    }
                    else if (options.hasOption(token))
                    {
                        tokens.add(token);
                    }
                    // requires bursting
                    else
                    {
                        burstToken(token, stopAtNonOption);
                    }
                }
                else
                {
                    tokens.add(token);
                }
            }

            gobble(iter);
        }

        return (String[]) tokens.toArray(new String[tokens.size()]);
    }

Note: In the else block for stopAtNonOption false, we removed the `else if (stopAtNonOption)` branch because stopAtNonOption is false. Also, for non-option tokens (not starting with "-"), we simply add to tokens. That matches the original behavior when stopAtNonOption is false.

We also removed the `else if (stopAtNonOption)` from the original chain because it's now handled at the top.

