public void testAttributeNamespaceFromContext() {
    // Create a simple XML document with JDOM
    Element root = new Element("root", Namespace.getNamespace("", ""));
    // Add an attribute with namespace URI "http://example.com/ns" and prefix "doc"
    Namespace docNs = Namespace.getNamespace("doc", "http://example.com/ns");
    root.setAttribute("attr", "value", docNs);
    
    // Create a JXPathContext with this document
    JXPathContext context = JXPathContext.newContext(root);
    // Register a different prefix "ctx" for the same URI
    context.registerNamespace("ctx", "http://example.com/ns");
    
    // Now, evaluate XPath for ctx:attr
    Object value = context.getValue("//@ctx:attr");
    assertEquals("Should find attribute with namespace from context", "value", value);
    
    // Also test with wildcard
    Object count = context.getValue("count(//@ctx:*)");
    assertEquals("Should count one attribute with that namespace", new Double(1), count);
    
    // Test with no prefix, attribute with no namespace
    root.setAttribute("noNsAttr", "noNsValue");
    Object noNsValue = context.getValue("//@noNsAttr");
    assertEquals("Attribute with no namespace", "noNsValue", noNsValue);
}

