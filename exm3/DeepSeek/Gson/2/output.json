public void testTypeHierarchyFactoryDoesNotMatchSubclass() {
  class Base {}
  class Sub extends Base {}
  
  TypeAdapter<Base> baseAdapter = new TypeAdapter<Base>() {
    @Override public void write(JsonWriter out, Base value) throws IOException {}
    @Override public Base read(JsonReader in) throws IOException {
      // Return a Base instance
      return new Base();
    }
  };
  TypeAdapter<Sub> subAdapter = new TypeAdapter<Sub>() {
    @Override public void write(JsonWriter out, Sub value) throws IOException {}
    @Override public Sub read(JsonReader in) throws IOException {
      // Return a Sub instance
      return new Sub();
    }
  };
  
  TypeAdapterFactory baseFactory = TypeAdapters.newTypeHierarchyFactory(Base.class, baseAdapter);
  TypeAdapterFactory subFactory = new TypeAdapterFactory() {
    @Override public <T> TypeAdapter<T> create(Gson gson, TypeToken<T> type) {
      if (type.getRawType() == Sub.class) {
        return (TypeAdapter<T>) subAdapter;
      }
      return null;
    }
  };
  
  Gson gson = new GsonBuilder()
      .registerTypeAdapterFactory(baseFactory)
      .registerTypeAdapterFactory(subFactory)
      .create();
  
  // Deserialize empty object as Sub. With buggy, baseAdapter will be used and return Base, causing ClassCastException.
  // With fixed, subAdapter will be used and return Sub.
  Sub result = gson.fromJson("{}", Sub.class);
  // If baseAdapter was used, result would be Base and assignment would fail (ClassCastException).
  // So just reaching here means subAdapter was used. We can also assert result is Sub.
  assertTrue(result instanceof Sub);
}
```

