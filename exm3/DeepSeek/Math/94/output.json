public static int gcd(int u, int v) {
    // Handle zero cases without multiplication overflow
    if (u == 0 || v == 0) {
        if (u == Integer.MIN_VALUE || v == Integer.MIN_VALUE) {
            // gcd(0, MIN_VALUE) or gcd(MIN_VALUE, 0) would be 2^31, which overflows int
            throw new ArithmeticException("overflow: gcd is 2^31");
        }
        // At least one is zero, the other is non-zero (or both zero)
        // gcd(0,0) = 0, gcd(0, n) = |n|
        return Math.abs(u) + Math.abs(v); // but if both zero, returns 0; if one zero, returns |non-zero|
    }
    // original algorithm with negative numbers
    if (u > 0) {
        u = -u;
    }
    if (v > 0) {
        v = -v;
    }
    int k = 0;
    while ((u & 1) == 0 && (v & 1) == 0 && k < 31) {
        u /= 2;
        v /= 2;
        k++;
    }
    if (k == 31) {
        throw new ArithmeticException("overflow: gcd is 2^31");
    }
    int t = ((u & 1) == 1) ? v : -(u / 2);
    do {
        while ((t & 1) == 0) {
            t /= 2;
        }
        if (t > 0) {
            u = -t;
        } else {
            v = t;
        }
        t = (v - u) / 2;
    } while (t != 0);
    return -u * (1 << k);
}

