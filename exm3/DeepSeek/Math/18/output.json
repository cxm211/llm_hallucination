public boolean isFeasible(final double[] x) {
    if (boundaries == null) {
        return true;
    }
    final double EPS = 1e-12;
    for (int i = 0; i < x.length; i++) {
        double diff = boundaries[1][i] - boundaries[0][i];
        if (diff == 0.0) {
            // fixed dimension, always feasible
            continue;
        }
        if (x[i] < -EPS) {
            return false;
        }
        if (x[i] > 1.0 + EPS) {
            return false;
        }
    }
    return true;
}

