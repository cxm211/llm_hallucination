    private RealMatrix squareRoot(RealMatrix m) {
        final EigenDecomposition dec = new EigenDecomposition(m);
        // Get eigenvalues and eigenvectors
        RealMatrix V = dec.getV();
        RealMatrix D = dec.getD();
        // Compute square root of diagonal matrix
        int n = m.getRowDimension();
        RealMatrix sqrtD = MatrixUtils.createRealDiagonalMatrix(new double[n]);
        for (int i = 0; i < n; i++) {
            double eval = D.getEntry(i, i);
            // If eigenvalue is negative due to rounding errors, set to zero
            if (eval > 0) {
                sqrtD.setEntry(i, i, Math.sqrt(eval));
            } else {
                sqrtD.setEntry(i, i, 0.0);
            }
        }
        // Reconstruct: V * sqrt(D) * V^T if symmetric, else V * sqrt(D) * V^{-1}
        // Determine if matrix is symmetric
        // We can check if m is symmetric within tolerance
        double tolerance = 1e-10;
        boolean symmetric = true;
        for (int i = 0; i < n; i++) {
            for (int j = i+1; j < n; j++) {
                if (Math.abs(m.getEntry(i, j) - m.getEntry(j, i)) > tolerance) {
                    symmetric = false;
                    break;
                }
            }
            if (!symmetric) break;
        }
        if (symmetric) {
            RealMatrix VT = dec.getVT(); // transpose of V
            return V.multiply(sqrtD).multiply(VT);
        } else {
            // For non-symmetric, need inverse of V
            RealMatrix VInv = new LUDecomposition(V).getSolver().getInverse();
            return V.multiply(sqrtD).multiply(VInv);
        }
    }

