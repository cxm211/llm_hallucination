@Test
public void testCoshSinhThresholds() {
    double maxErr = 0;
    for (double x = -30.0; x <= 30.0; x += 0.01) {
        double tstCosh = FastMath.cosh(x);
        double refCosh = Math.cosh(x);
        double errCosh = FastMath.abs(refCosh - tstCosh) / FastMath.ulp(refCosh);
        maxErr = FastMath.max(maxErr, errCosh);

        double tstSinh = FastMath.sinh(x);
        double refSinh = Math.sinh(x);
        double errSinh = FastMath.abs(refSinh - tstSinh) / FastMath.ulp(refSinh);
        maxErr = FastMath.max(maxErr, errSinh);
    }
    Assert.assertEquals(0, maxErr, 3);
}

