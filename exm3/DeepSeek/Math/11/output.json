public void testMultivariateOddDimension() {
    final int dim = 3;
    final Random rng = new Random(12345); // fixed seed for reproducibility
    // generate random mean
    final double[] mu = new double[dim];
    for (int i = 0; i < dim; i++) {
        mu[i] = rng.nextDouble() * 10 - 5;
    }
    // generate random positive definite covariance matrix
    final double[][] A = new double[dim][dim];
    for (int i = 0; i < dim; i++) {
        for (int j = 0; j < dim; j++) {
            A[i][j] = rng.nextDouble() * 2 - 1;
        }
    }
    final RealMatrix matrixA = MatrixUtils.createRealMatrix(A);
    final RealMatrix sigmaMatrix = matrixA.multiply(matrixA.transpose()).scalarAdd(1.0); // ensure positive definite by adding identity? Actually A*A^T is positive semidefinite. Adding identity makes it positive definite.
    final double[][] sigma = sigmaMatrix.getData();

    final MultivariateNormalDistribution multi = new MultivariateNormalDistribution(mu, sigma);

    // compute determinant and inverse of sigma for expected density
    final LUDecomposition lu = new LUDecomposition(sigmaMatrix);
    final double det = lu.getDeterminant();
    final RealMatrix inverseSigma = lu.getSolver().getInverse();

    final int numCases = 10;
    final double tol = 1e-12;
    for (int k = 0; k < numCases; k++) {
        final double[] vals = new double[dim];
        for (int i = 0; i < dim; i++) {
            vals[i] = rng.nextDouble() * 10 - 5;
        }
        // compute exponent term manually
        final RealVector d = new ArrayRealVector(vals).subtract(new ArrayRealVector(mu));
        final double exponent = -0.5 * d.dotProduct(inverseSigma.operate(d));
        // compute constant factor
        final double constant = Math.pow(2 * Math.PI, -0.5 * dim) * Math.pow(det, -0.5);
        final double expected = constant * Math.exp(exponent);
        final double actual = multi.density(vals);
        Assert.assertEquals(expected, actual, tol);
    }
}

