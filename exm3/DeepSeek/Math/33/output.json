@Test
public void testDropPhase1WithBasicArtificial() {
    LinearObjectiveFunction f = new LinearObjectiveFunction(new double[] { 1, 1 }, 0); // maximize x1 + x2

    ArrayList<LinearConstraint> constraints = new ArrayList<LinearConstraint>();
    constraints.add(new LinearConstraint(new double[] { 1, 1 }, Relationship.EQ, 1)); // x1 + x2 = 1

    double epsilon = 1e-6;
    SimplexSolver solver = new SimplexSolver();
    PointValuePair solution = solver.optimize(f, constraints, GoalType.MAXIMIZE, false);

    // The optimal solution should be x1=1, x2=0 or x1=0, x2=1, but with maximize x1+x2, on the line x1+x2=1, the value is 1.
    // Since the objective is x1+x2, and constraint x1+x2=1, the maximum value is 1, achieved at any point on the line.
    // But with non-negativity, the feasible points are x1>=0, x2>=0, x1+x2=1, so value is always 1.
    Assert.assertEquals(1.0, solution.getValue(), epsilon);
    // The point should satisfy x1+x2=1
