public static Vector3D crossProduct(final Vector3D v1, final Vector3D v2) {
    // rescale to avoid infinite intermediate values
    double scaleX = FastMath.abs(v1.getX());
    double scaleY = FastMath.abs(v1.getY());
    double scaleZ = FastMath.abs(v1.getZ());
    double max = FastMath.max(scaleX, FastMath.max(scaleY, scaleZ));
    scaleX = FastMath.abs(v2.getX());
    scaleY = FastMath.abs(v2.getY());
    scaleZ = FastMath.abs(v2.getZ());
    max = FastMath.max(max, FastMath.max(scaleX, FastMath.max(scaleY, scaleZ)));
    if (max <= 0) {
        return ZERO;
    }
    double invMax = 1.0 / max;
    Vector3D v1s = new Vector3D(v1.getX() * invMax, v1.getY() * invMax, v1.getZ() * invMax);
    Vector3D v2s = new Vector3D(v2.getX() * invMax, v2.getY() * invMax, v2.getZ() * invMax);
    // compute rho
    double rho = (v1s.getX() * v2s.getX() + v1s.getY() * v2s.getY() + v1s.getZ() * v2s.getZ()) /
                 (v2s.getX() * v2s.getX() + v2s.getY() * v2s.getY() + v2s.getZ() * v2s.getZ());
    // round rho to 8 bits
    rho = Math.rint(rho * 256.0) / 256.0;
    // compute v3
    double v3x = v1s.getX() - rho * v2s.getX();
    double v3y = v1s.getY() - rho * v2s.getY();
    double v3z = v1s.getZ() - rho * v2s.getZ();
    // compute cross product
    double cx = v3y * v2s.getZ() - v3z * v2s.getY();
    double cy = v3z * v2s.getX() - v3x * v2s.getZ();
    double cz = v3x * v2s.getY() - v3y * v2s.getX();
    // rescale back
    return new Vector3D(cx * max, cy * max, cz * max);
}

