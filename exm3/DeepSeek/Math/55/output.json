public static Vector3D crossProduct(Vector3D v1, Vector3D v2) {
    // rescale to avoid infinite intermediate values
    double norm1 = v1.getNorm();
    double norm2 = v2.getNorm();
    double scale = FastMath.min(norm1, norm2);
    if (scale == 0) {
        return ZERO;
    }
    double invScale = 1.0 / scale;
    Vector3D v1s = v1.scalarMultiply(invScale);
    Vector3D v2s = v2.scalarMultiply(invScale);
    // compute rho
    double rho = v1s.dotProduct(v2s) / v2s.dotProduct(v2s);
    // round rho to 8 bits
    rho = Math.rint(rho * 256.0) / 256.0;
    // compute v3
    Vector3D v3 = v1s.subtract(v2s.scalarMultiply(rho));
    // compute cross product
    Vector3D cross = v3.crossProduct(v2s);
    // rescale back
    return cross.scalarMultiply(scale);
}

