public static Vector3D crossProduct(final Vector3D v1, final Vector3D v2) {
    // rescale to avoid infinite intermediate values
    double scale = FastMath.max(FastMath.abs(v1.x), FastMath.abs(v1.y), FastMath.abs(v1.z),
                                FastMath.abs(v2.x), FastMath.abs(v2.y), FastMath.abs(v2.z));
    if (scale == 0) {
        return ZERO;
    }
    final double invScale = 1.0 / scale;
    final double v1x = v1.x * invScale;
    final double v1y = v1.y * invScale;
    final double v1z = v1.z * invScale;
    final double v2x = v2.x * invScale;
    final double v2y = v2.y * invScale;
    final double v2z = v2.z * invScale;
    final double dot = v1x * v2x + v1y * v2y + v1z * v2z;
    final double dot2 = v2x * v2x + v2y * v2y + v2z * v2z;
    if (dot2 == 0.0) {
        return ZERO;
    }
    final double rho = dot / dot2;
    // round to 8 bits
    final double rho8 = Math.rint(rho * 256.0) / 256.0;
    final double v3x = v1x - rho8 * v2x;
    final double v3y = v1y - rho8 * v2y;
    final double v3z = v1z - rho8 * v2z;
    final double cx = v3y * v2z - v3z * v2y;
    final double cy = v3z * v2x - v3x * v2z;
    final double cz = v3x * v2y - v3y * v2x;
    // rescale back
    final double rescale = scale * scale;
    return new Vector3D(cx * rescale, cy * rescale, cz * rescale);
}

